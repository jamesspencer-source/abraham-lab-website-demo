---
layout: layouts/base.njk
title: Contact
description: Contact information for the Abraham Lab.
permalink: /contact/index.html
---
<section class="page-hero page-hero--light">
  <div class="container page-hero__content reveal">
    <p class="eyebrow">Contact</p>
    <h1>Abraham Lab</h1>
    <p>{{ site.contact.department }}</p>
  </div>
</section>

<section class="section section--bordered">
  <div class="container location-layout">
    <div class="location-layout__content">
      <div class="section-heading section-heading--compact reveal">
        <p class="eyebrow">Visit</p>
        <h2>Laboratory location and direct contacts.</h2>
        <p>
          Use the information below for scientific correspondence, operations questions, and directions to
          the laboratory.
        </p>
      </div>

      <div class="contact-detail-grid">
        <article class="contact-block reveal">
          <p class="eyebrow">Address</p>
          <h3>Laboratory location</h3>
          {% for line in site.contact.addressLines %}
            <p>{{ line }}</p>
          {% endfor %}
          <p><a class="text-link" href="{{ site.contact.mapUrl }}" target="_blank" rel="noreferrer">Open in Google Maps</a></p>
        </article>

        <article class="contact-block reveal">
          <p class="eyebrow">Email</p>
          <h3>Scientific and administrative contact</h3>
          <p><strong>Jonathan Abraham</strong><br /><a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a></p>
          <p><strong>James Spencer</strong><br /><a href="mailto:{{ site.contact.managerEmail }}">{{ site.contact.managerEmail }}</a></p>
        </article>

        <article class="contact-block reveal">
          <p class="eyebrow">Affiliation</p>
          <h3>Institutional affiliation</h3>
          <p>{{ site.institutionTitle }}</p>
          <ul class="clean-list">
            {% for affiliation in site.affiliations %}
              <li><a href="{{ affiliation.href }}" target="_blank" rel="noreferrer">{{ affiliation.shortName or affiliation.name }}</a></li>
            {% endfor %}
          </ul>
        </article>
      </div>
    </div>

    <aside class="map-panel reveal">
      <iframe
        src="{{ site.contact.mapEmbedUrl }}"
        title="Map showing the Abraham Lab at 77 Avenue Louis Pasteur in Boston"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <div class="map-panel__actions">
        <a class="button button--secondary" href="{{ site.contact.mapUrl }}" target="_blank" rel="noreferrer">Open external map</a>
      </div>
    </aside>
  </div>
</section>
