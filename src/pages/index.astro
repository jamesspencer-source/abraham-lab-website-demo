---
import BaseLayout from "../layouts/BaseLayout.astro";
import MapWidget from "../components/MapWidget.astro";
import { siteData } from "../data/site";
import { researchPrograms } from "../data/research";
import { publications } from "../data/publications";
import { newsItems } from "../data/news";
import { featuredOnly, formatMonthYear, limitItems, withBase } from "../lib/content";

const featuredPublications = featuredOnly(publications);
const leadPublication = featuredPublications[0];
const recentNews = limitItems(newsItems, 4);
const [leadFigure] = siteData.heroFigures;
const heroVisual = leadPublication?.image
  ? {
      image: leadPublication.image,
      alt: leadPublication.imageAlt ?? leadFigure.alt,
      imagePosition: leadPublication.imagePosition
    }
  : {
      image: leadFigure.image,
      alt: leadFigure.alt,
      imagePosition: leadFigure.imagePosition
    };
---

<BaseLayout pageClass="page-home">
  <section class="marquee">
    <div class="marquee__shell shell">
      <div class="marquee__grid">
        <div class="marquee__copy">
          <p class="eyebrow reveal">Mechanistic virology</p>
          <h1 class="reveal">{siteData.heroTitle}</h1>
          <p class="marquee__deck reveal">{siteData.heroDeck}</p>

          <div class="button-row reveal">
            <a class="button button--primary" href={withBase("/research/")}>Research</a>
            <a class="button button--ghost" href={withBase("/publications/")}>Publication record</a>
          </div>
        </div>

        <aside class="hero-dossier reveal">
          <div class="hero-dossier__media frame" style={heroVisual.imagePosition ? `--media-position: ${heroVisual.imagePosition};` : undefined}>
            <img src={withBase(heroVisual.image)} alt={heroVisual.alt} loading="eager" />
          </div>
          <div class="hero-dossier__body">
            <p class="eyebrow">Current publication</p>
            <h2>{leadPublication?.title ?? leadFigure.title}</h2>
            <p class="hero-dossier__meta">
              {leadPublication
                ? [leadPublication.journal, leadPublication.publishedAt ? formatMonthYear(leadPublication.publishedAt) : undefined, leadPublication.pmid ? `PMID ${leadPublication.pmid}` : undefined].filter(Boolean).join(" | ")
                : leadFigure.note}
            </p>
            {leadPublication?.summary && <p>{leadPublication.summary}</p>}

            <dl class="hero-dossier__facts">
              {siteData.heroFacts.map((item) => (
                <div class="hero-dossier__fact">
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))}
            </dl>

            {leadPublication ? (
              <a class="text-link" href={leadPublication.link} target="_blank" rel="noreferrer">Open paper</a>
            ) : (
              leadFigure.href && <a class="text-link" href={leadFigure.href} target="_blank" rel="noreferrer">Open source</a>
            )}
          </div>
        </aside>
      </div>

      <div class="hero-proof reveal">
        {siteData.heroProof.map((item) => (
          <article class="hero-proof__item">
            <p>{item.label}</p>
            {item.href ? (
              <a href={item.href} target="_blank" rel="noreferrer">{item.value}</a>
            ) : (
              <h2>{item.value}</h2>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="institution-band">
    <div class="shell institution-band__grid">
      <div class="institution-band__copy reveal">
        <p class="eyebrow">{siteData.institutionLabel}</p>
        <h2 class="institution-band__title">
          {siteData.contact.institutionDisplayLines?.map((line) => (
            <span class={line.includes("Blavatnik Institute") ? "u-nowrap" : undefined}>{line}</span>
          ))}
        </h2>
        <p>{siteData.institutionSummary}</p>
      </div>

      <div class="institution-band__rail">
        {siteData.affiliations.map((affiliation) => (
          <a class="institution-band__item reveal" href={affiliation.href} target="_blank" rel="noreferrer">
            <div class="institution-band__logo">
              <img src={withBase(affiliation.logo)} alt={affiliation.alt} loading="lazy" />
            </div>
            <div>
              <p class="institution-band__name">{affiliation.shortName ?? affiliation.name}</p>
              {affiliation.note && <p class="institution-band__note">{affiliation.note}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--flagship home-research">
    <div class="shell page-section__header page-section__header--wide">
      <div class="reveal">
        <p class="eyebrow">Scientific questions</p>
        <h2>Three research areas spanning entry, neutralization, and replication.</h2>
      </div>
      <div class="reveal">
        <p>
          Across current publications, the lab focuses on receptor engagement and entry, glycoprotein
          architecture and antibody recognition, and polymerase assemblies that govern replication,
          inhibition, and resistance.
        </p>
      </div>
    </div>

    <div class="shell home-program-list">
      {researchPrograms.map((item, index) => (
        <article class="home-program reveal">
          <div class="home-program__visual frame" style={item.imagePosition ? `--media-position: ${item.imagePosition};` : undefined}>
            <img src={withBase(item.image)} alt={item.imageAlt} loading="lazy" />
          </div>
          <div class="home-program__body">
            <p class="section-index">{String(index + 1).padStart(2, "0")}</p>
            <h3>{item.title}</h3>
            <p class="home-program__question">{item.keyQuestion}</p>
            <p>{item.summary}</p>
          </div>
          <div class="home-program__rail">
            <div class="metadata-stack">
              <p class="metadata-label">Representative systems</p>
              <p>{item.systems.join(" | ")}</p>
            </div>
            {item.papers[0] && (
              <div class="metadata-stack">
                <p class="metadata-label">Representative paper</p>
                <a class="text-link" href={item.papers[0].href} target="_blank" rel="noreferrer">{item.papers[0].title}</a>
                <p>{item.papers[0].journal} | {item.papers[0].year}</p>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--utility updates-band">
    <div class="shell page-section__header page-section__header--compact">
      <div class="reveal">
        <p class="eyebrow">Recent updates</p>
        <h2>Selected updates on publications, awards, invited talks, and institutional coverage.</h2>
      </div>
    </div>

    <div class="shell updates-ledger">
      {recentNews.map((item) => (
        <article class="updates-ledger__row reveal">
          <div class="updates-ledger__meta">
            <p>{formatMonthYear(item.date)}</p>
            <span>{item.category}</span>
          </div>
          <div class="updates-ledger__body">
            <p class="metadata-label">{item.source}</p>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </div>
          <div class="updates-ledger__action">
            <a class="text-link" href={item.link} target="_blank" rel="noreferrer">{item.linkLabel ?? "Open source"}</a>
          </div>
        </article>
      ))}

      <div class="updates-ledger__footer reveal">
        <a class="button button--ghost" href={withBase("/news/")}>All updates</a>
      </div>
    </div>
  </section>

  <section class="section section--utility location-band">
    <div class="shell location-band__grid">
      <div class="location-band__copy reveal">
        <p class="eyebrow">Location</p>
        <h2>{siteData.contact.homeLocationLabel}</h2>
        <p class="location-band__institution">
          <span>{siteData.contact.institutionDisplayLines?.[0]}</span>
          <span class="u-nowrap">{siteData.contact.institutionDisplayLines?.[1]}</span>
        </p>
        <p>For collaborations, speaking requests, and administrative inquiries.</p>
        <div class="location-list">
          {siteData.contact.addressLines.map((line) => <p>{line}</p>)}
        </div>
        <div class="button-row">
          <a class="button button--primary" href={`mailto:${siteData.contact.email}`}>Email Jonathan Abraham</a>
          <a class="button button--ghost" href={withBase("/contact/")}>Contact page</a>
        </div>
      </div>

      <MapWidget
        mode="home"
        eyebrow="Campus map"
        description="Harvard Medical School campus"
      />
    </div>
  </section>
</BaseLayout>
