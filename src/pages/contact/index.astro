---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MapWidget from "../../components/MapWidget.astro";
import { siteData } from "../../data/site";
---

<BaseLayout title="Contact" description="Contact information for the Abraham Lab.">
  <section class="interior-hero interior-hero--contact">
    <div class="shell interior-hero__grid">
      <div class="interior-hero__copy reveal">
        <p class="eyebrow">Contact</p>
        <h1>For collaborations, speaking requests, and administrative inquiries.</h1>
        <p>
          The Abraham Lab is based in the Department of Microbiology, Blavatnik Institute, Harvard Medical School,
          in Boston's Longwood Medical Area.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--utility contact-band">
    <div class="shell contact-band__grid">
      <div class="contact-band__content">
        <div class="contact-cards">
          <article class="metadata-panel reveal">
            <p class="metadata-label">Address</p>
            {siteData.contact.addressLines.map((line) => <p>{line}</p>)}
          </article>

          <article class="metadata-panel reveal">
            <p class="metadata-label">Contact</p>
            <p><strong>Jonathan Abraham</strong><br /><a href={`mailto:${siteData.contact.email}`}>{siteData.contact.email}</a></p>
            <p><strong>James Spencer</strong><br /><a href={`mailto:${siteData.contact.managerEmail}`}>{siteData.contact.managerEmail}</a></p>
          </article>

          <article class="metadata-panel reveal">
            <p class="metadata-label">Affiliation</p>
            <p>{siteData.institutionTitle}</p>
            <ul class="clean-list metadata-list">
              {siteData.affiliations.map((affiliation) => (
                <li><a href={affiliation.href} target="_blank" rel="noreferrer">{affiliation.shortName ?? affiliation.name}</a></li>
              ))}
            </ul>
          </article>
        </div>
      </div>

      <MapWidget
        mode="contact"
        eyebrow="Campus map"
        description={`${siteData.contact.mapBuilding} · ${siteData.contact.mapContext}`}
      />
    </div>
  </section>
</BaseLayout>
