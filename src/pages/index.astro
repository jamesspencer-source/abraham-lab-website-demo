---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResearchChapter from "../components/ResearchChapter.astro";
import MapWidget from "../components/MapWidget.astro";
import { siteData } from "../data/site";
import { researchPrograms } from "../data/research";
import { publications } from "../data/publications";
import { newsItems } from "../data/news";
import { featuredOnly, formatMonthYear, limitItems, withBase } from "../lib/content";

const featuredPublications = featuredOnly(publications);
const leadPublication = featuredPublications[0];
const publicationRail = featuredPublications.slice(1, 5);
const recentNews = limitItems(newsItems, 4);
const [leadFigure, ...supportFigures] = siteData.heroFigures;
---

<BaseLayout pageClass="page-home">
  <section class="marquee">
    <div class="marquee__shell shell">
      <div class="marquee__grid">
        <div class="marquee__copy">
          <p class="eyebrow reveal">Structural virology | molecular virology | biophysics</p>
          <h1 class="reveal">{siteData.heroTitle}</h1>
          <p class="marquee__deck reveal">{siteData.heroDeck}</p>

          <div class="button-row reveal">
            <a class="button button--primary" href={withBase("/research/")}>Research</a>
            <a class="button button--ghost" href={withBase("/publications/")}>Selected publications</a>
          </div>

          <dl class="hero-facts reveal">
            {siteData.heroFacts.map((item) => (
              <div class="hero-facts__item">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="science-stage reveal">
          <article class="science-stage__primary science-card frame" style={leadFigure.imagePosition ? `--media-position: ${leadFigure.imagePosition};` : undefined}>
            <img src={withBase(leadFigure.image)} alt={leadFigure.alt} loading="eager" />
            <div class="science-card__caption">
              <p class="science-card__label">{leadFigure.label}</p>
              <h2>{leadFigure.title}</h2>
              {leadFigure.note && <p>{leadFigure.note}</p>}
              {leadFigure.href && <a class="text-link" href={leadFigure.href} target="_blank" rel="noreferrer">Open paper</a>}
            </div>
          </article>

          <div class="science-stage__stack">
            {supportFigures.map((item) => (
              <article class="science-card frame" style={item.imagePosition ? `--media-position: ${item.imagePosition};` : undefined}>
                <img src={withBase(item.image)} alt={item.alt} loading="lazy" />
                <div class="science-card__caption">
                  <p class="science-card__label">{item.label}</p>
                  <h2>{item.title}</h2>
                  {item.note && <p>{item.note}</p>}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <div class="hero-proof reveal">
        {siteData.heroProof.map((item) => (
          <article class="hero-proof__item">
            <p>{item.label}</p>
            {item.href ? (
              <a href={item.href} target="_blank" rel="noreferrer">{item.value}</a>
            ) : (
              <h2>{item.value}</h2>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="institution-band">
    <div class="shell institution-band__grid">
      <div class="institution-band__copy reveal">
        <p class="eyebrow">{siteData.institutionLabel}</p>
        <h2>{siteData.institutionTitle}</h2>
        <p>{siteData.institutionSummary}</p>
      </div>

      <div class="institution-band__rail">
        {siteData.affiliations.map((affiliation) => (
          <a class="institution-band__item reveal" href={affiliation.href} target="_blank" rel="noreferrer">
            <div class="institution-band__logo">
              <img src={withBase(affiliation.logo)} alt={affiliation.alt} loading="lazy" />
            </div>
            <div>
              <p class="institution-band__name">{affiliation.shortName ?? affiliation.name}</p>
              {affiliation.note && <p class="institution-band__note">{affiliation.note}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--flagship home-research">
    <div class="shell page-section__header page-section__header--wide">
      <div class="reveal">
        <p class="eyebrow">Scientific program</p>
        <h2>Three connected research programs centered on public, mechanistic proof.</h2>
      </div>
      <div class="reveal">
        <p>
          The Abraham Lab studies how viruses enter cells, how antibodies block or fail to block infection,
          and how replication complexes create therapeutic leverage. The emphasis is on mechanisms that can be
          traced directly to public papers, public structures, and public institutional reporting.
        </p>
      </div>
    </div>

    <div class="shell research-chapter-list">
      {researchPrograms.map((item, index) => (
        <ResearchChapter
          index={index + 1}
          title={item.title}
          keyQuestion={item.keyQuestion}
          importance={item.importance}
          summary={item.summary}
          paragraphs={item.paragraphs}
          systems={item.systems}
          methods={item.methods}
          papers={item.papers}
          image={item.image}
          imageAlt={item.imageAlt}
          imagePosition={item.imagePosition}
          reverse={index % 2 === 1}
        />
      ))}
    </div>
  </section>

  {leadPublication && (
    <section class="section section--flagship publication-band">
      <div class="shell publication-band__grid">
        <div class="publication-band__body reveal">
          <p class="eyebrow">Lead publication</p>
          <h2>{leadPublication.title}</h2>
          <p class="publication-band__meta">
            {[leadPublication.journal, leadPublication.publishedAt ? formatMonthYear(leadPublication.publishedAt) : undefined, leadPublication.doi].filter(Boolean).join(" | ")}
          </p>
          <p class="publication-band__summary">{leadPublication.summary}</p>
          <p class="citation-text">{leadPublication.citation}</p>
          <div class="button-row">
            <a class="button button--primary" href={leadPublication.link} target="_blank" rel="noreferrer">Read publication</a>
            <a class="button button--ghost" href={withBase("/publications/")}>View archive</a>
          </div>
        </div>

        <div class="publication-band__visual reveal">
          <div class="publication-band__image frame" style={leadPublication.imagePosition ? `--media-position: ${leadPublication.imagePosition};` : undefined}>
            <img src={withBase(leadPublication.image!)} alt={leadPublication.imageAlt!} loading="lazy" />
          </div>
        </div>

        <aside class="publication-band__rail reveal">
          <p class="metadata-label">Recent papers</p>
          <div class="reference-list">
            {publicationRail.map((item) => (
              <article class="reference-card">
                <p class="reference-card__meta">{item.journal ?? "Publication"} | {item.year}</p>
                <a class="reference-card__title" href={item.link} target="_blank" rel="noreferrer">{item.title}</a>
                {item.summary && <p class="reference-card__note">{item.summary}</p>}
              </article>
            ))}
          </div>
        </aside>
      </div>
    </section>
  )}

  <section class="section section--utility updates-band">
    <div class="shell page-section__header page-section__header--compact">
      <div class="reveal">
        <p class="eyebrow">Recent updates</p>
        <h2>Public research updates and institutional coverage.</h2>
      </div>
      <div class="reveal">
        <p>Selected publications, institutional features, and science-facing updates from the Abraham Lab.</p>
      </div>
    </div>

    <div class="shell updates-ledger">
      {recentNews.map((item) => (
        <article class="updates-ledger__row reveal">
          <div class="updates-ledger__meta">
            <p>{formatMonthYear(item.date)}</p>
            <span>{item.category}</span>
          </div>
          <div class="updates-ledger__body">
            <p class="metadata-label">{item.source}</p>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </div>
          <div class="updates-ledger__action">
            <a class="text-link" href={item.link} target="_blank" rel="noreferrer">{item.linkLabel ?? "Open source"}</a>
          </div>
        </article>
      ))}

      <div class="updates-ledger__footer reveal">
        <a class="button button--ghost" href={withBase("/news/")}>All updates</a>
      </div>
    </div>
  </section>

  <section class="section section--utility location-band">
    <div class="shell location-band__grid">
      <div class="location-band__copy reveal">
        <p class="eyebrow">Location</p>
        <h2>{siteData.contact.homeLocationLabel}</h2>
        <p>For collaborations, speaking requests, and administrative inquiries.</p>
        <div class="location-list">
          {siteData.contact.addressLines.map((line) => <p>{line}</p>)}
        </div>
        <div class="button-row">
          <a class="button button--primary" href={`mailto:${siteData.contact.email}`}>Email Jonathan Abraham</a>
          <a class="button button--ghost" href={withBase("/contact/")}>Contact page</a>
        </div>
      </div>

      <MapWidget
        mode="home"
        eyebrow="Campus map"
        description={`${siteData.contact.addressLines[0]} · ${siteData.contact.addressLines[1]}`}
      />
    </div>
  </section>
</BaseLayout>
