---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { jonathanProfile } from "../../data/jonathan";
import { withBase } from "../../lib/content";
---

<BaseLayout
  title="Jonathan Abraham"
  description="Profile of Jonathan Abraham, M.D., Ph.D."
  socialImage={jonathanProfile.portrait}
>
  <section class="profile-hero">
    <div class="shell profile-hero__grid">
      <div class="profile-hero__copy reveal">
        <p class="eyebrow">Jonathan Abraham</p>
        <h1>{jonathanProfile.name}</h1>
        <p class="profile-hero__title">{jonathanProfile.title}</p>
        <p class="profile-hero__title">{jonathanProfile.secondaryTitle}</p>
        <p class="profile-hero__overview">{jonathanProfile.overview}</p>
      </div>
      <div class="profile-hero__portrait frame reveal" style={jonathanProfile.portraitPosition ? `--media-position: ${jonathanProfile.portraitPosition};` : undefined}>
        <img src={withBase(jonathanProfile.portrait)} alt={jonathanProfile.portraitAlt} loading="lazy" />
      </div>
      <div class="profile-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Appointments</p>
          <ul class="clean-list metadata-list">
            {jonathanProfile.appointments.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--flagship profile-band">
    <div class="shell profile-band__grid">
      <div class="profile-band__body reveal">
        <p class="eyebrow">Scientific biography</p>
        {jonathanProfile.biography.map((paragraph) => <p>{paragraph}</p>)}
        <div class="button-row">
          <a class="button button--primary" href={withBase("/publications/")}>View publications</a>
          <a class="button button--ghost" href={withBase("/contact/")}>Contact</a>
        </div>
      </div>

      <div class="profile-band__rail reveal">
        <article class="metadata-panel">
          <p class="metadata-label">Distinctions</p>
          <ul class="clean-list metadata-list">
            {jonathanProfile.distinctions.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="metadata-panel">
          <p class="metadata-label">Research focus</p>
          <ul class="clean-list metadata-list">
            {jonathanProfile.focusAreas.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="metadata-panel">
          <p class="metadata-label">Selected papers</p>
          <ul class="clean-list metadata-list">
            {jonathanProfile.representativeWork.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
