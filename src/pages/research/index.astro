---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResearchChapter from "../../components/ResearchChapter.astro";
import { researchPrograms } from "../../data/research";
---

<BaseLayout
  title="Research"
  description="Research themes in viral entry, antiviral antibodies, and viral polymerase biology at the Abraham Lab."
>
  <section class="page-hero page-hero--research">
    <div class="shell page-hero__grid">
      <div class="page-hero__copy reveal">
        <p class="eyebrow">Research</p>
        <h1>Mechanistic chapters in viral infection biology.</h1>
        <p>
          The Abraham Lab's public work concentrates on receptor recognition, glycoprotein architecture,
          antibody interfaces, and polymerase assemblies in medically important viruses. The emphasis is on
          experimentally resolved mechanism and source-backed public results.
        </p>
      </div>

      <div class="page-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Core systems</p>
          <ul class="clean-list metadata-list">
            <li>alphaviruses</li>
            <li>arenaviruses</li>
            <li>henipaviruses</li>
            <li>herpesviruses</li>
          </ul>
        </div>
        <div class="metadata-stack">
          <p class="metadata-label">Core methods</p>
          <ul class="clean-list metadata-list">
            <li>cryo-EM and crystallography</li>
            <li>protein biochemistry</li>
            <li>functional virology</li>
            <li>receptor and antibody analysis</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--flagship">
    <div class="shell section-heading section-heading--split">
      <div class="reveal">
        <p class="eyebrow">Technical atlas</p>
        <h2>Three scientific programs anchored to public papers and resolved mechanism.</h2>
      </div>
      <div class="reveal">
        <p>
          Each chapter below is tied to published work, representative systems, and experimental methods already
          described in the public record.
        </p>
      </div>
    </div>
    <div class="shell research-chapter-list">
      {researchPrograms.map((item, index) => (
        <ResearchChapter
          index={index + 1}
          title={item.title}
          keyQuestion={item.keyQuestion}
          importance={item.importance}
          summary={item.summary}
          paragraphs={item.paragraphs}
          systems={item.systems}
          methods={item.methods}
          papers={item.papers}
          image={item.image}
          imageAlt={item.imageAlt}
          imagePosition={item.imagePosition}
          headingTag="h2"
        />
      ))}
    </div>
  </section>

  <section class="section section--utility support-band">
    <div class="shell methods-band__grid">
      <div class="reveal">
        <p class="eyebrow">Experimental approach</p>
        <h2>Structure, biochemistry, and functional virology in parallel.</h2>
      </div>
      <div class="reveal">
        <p>
          The laboratory combines structural biology, protein biochemistry, receptor analysis, and
          infection-focused functional experiments. Across projects, the goal is to connect molecular
          architecture to experimentally tractable mechanisms.
        </p>
      </div>
      <div class="reveal methods-band__rail">
        <p>CRISPR-based discovery</p>
        <p>Biophysics and protein biochemistry</p>
        <p>Cryo-EM and crystallography</p>
        <p>Cellular infection assays</p>
      </div>
    </div>
  </section>
</BaseLayout>
