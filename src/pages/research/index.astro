---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/content";

const destination = withBase("/publications/#research-atlas");
---

<BaseLayout
  title="Research"
  description="Published research themes from the Abraham Lab."
  canonicalPath="/publications/"
  socialImage="/assets/images/publications/arenavirus-gpc.jpeg"
>
  <section class="page-hero page-hero--research-legacy">
    <div class="shell page-hero__grid">
      <div class="page-hero__copy reveal">
        <p class="eyebrow">Research</p>
        <h1>Research themes now live within the publications record.</h1>
        <p>
          Scientific depth for the Abraham Lab is organized within the publications page, where
          mechanistic themes sit directly alongside representative papers, figures, and the citation archive.
        </p>
        <div class="button-row">
          <a class="button button--primary" href={destination}>Go to Publications</a>
        </div>
      </div>
      <div class="page-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Scientific depth</p>
          <p>Lead paper, recent proof, research atlas, and full archive</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
