---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { newsItems } from "../../data/news";
import { formatDateLabel } from "../../lib/content";
import { siteData } from "../../data/site";
---

<BaseLayout title="News" description="Selected updates from the Abraham Lab.">
  <section class="page-hero page-hero--news">
    <div class="shell page-hero__grid">
      <div class="page-hero__copy reveal">
        <p class="eyebrow">News</p>
        <h1>Selected updates on publications, awards, invited talks, and institutional coverage from the Abraham Lab.</h1>
        <p>
          Recent publications, institutional coverage, and scientific distinctions related to the laboratory.
        </p>
      </div>
      <div class="page-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Follow the lab</p>
          <ul class="clean-list metadata-list">
            <li><a href={siteData.social.x} target="_blank" rel="noreferrer">Abraham Lab on X</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--utility updates-band">
    <div class="shell updates-ledger">
      {newsItems.map((item) => (
        <article class="updates-ledger__row reveal">
          <div class="updates-ledger__meta">
            <p>{formatDateLabel(item.date)}</p>
            <span>{item.category}</span>
          </div>
          <div class="updates-ledger__body">
            <p class="metadata-label">{item.source}</p>
            <h2>{item.title}</h2>
            <p>{item.summary}</p>
          </div>
          <div class="updates-ledger__action">
            <a class="text-link" href={item.link} target="_blank" rel="noreferrer">{item.linkLabel ?? "Open source"}</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
