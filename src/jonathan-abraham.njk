---
layout: layouts/base.njk
title: Jonathan Abraham
description: Profile of Jonathan Abraham, M.D., Ph.D.
permalink: /jonathan-abraham/index.html
---
{% set selectedPubs = publications | featuredOnly | limit(4) %}

<section class="page-hero page-hero--light">
  <div class="container page-hero__shell">
    <div class="page-hero__content reveal">
      <p class="eyebrow">Jonathan Abraham</p>
      <h1>{{ jonathan.name }}</h1>
      <p>{{ jonathan.title }}<br />{{ jonathan.secondaryTitle }}</p>
    </div>
  </div>
</section>

<section class="section section--flagship section--bordered">
  <div class="container profile-frame">
    <div class="profile-frame__portrait reveal">
      <img src="{{ jonathan.portrait | withBase }}" alt="{{ jonathan.portraitAlt }}" loading="lazy" />
    </div>
    <div class="profile-frame__content reveal">
      <p class="eyebrow">Scientific biography</p>
      <p class="profile-frame__lead">{{ jonathan.overview }}</p>
      {% for paragraph in jonathan.biography %}
        <p>{{ paragraph }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--soft section--utility">
  <div class="container profile-facts">
    <article class="fact-column reveal">
      <p class="eyebrow">Appointments</p>
      <ul class="clean-list">
        {% for item in jonathan.appointments %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </article>

    <article class="fact-column reveal">
      <p class="eyebrow">Distinctions</p>
      <ul class="clean-list">
        {% for item in jonathan.distinctions %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </article>

    <article class="fact-column reveal">
      <p class="eyebrow">Research focus</p>
      <ul class="clean-list">
        {% for item in jonathan.focusAreas %}
          <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </article>
  </div>
</section>

<section class="section section--utility">
  <div class="container section-heading reveal">
    <p class="eyebrow">Representative work</p>
    <h2>Selected publications aligned with the laboratory program.</h2>
  </div>

  <div class="container citation-list">
    {% for item in selectedPubs %}
      <article class="citation-list__item reveal">
        <p class="citation-list__meta">{{ item.year }}</p>
        <div class="citation-list__body">
          <h3>{{ item.title }}</h3>
          <p>{{ item.summary }}</p>
          <p class="citation-text">{{ item.citation }}</p>
          <a class="text-link" href="{{ item.link }}" target="_blank" rel="noreferrer">Read paper</a>
        </div>
      </article>
    {% endfor %}
  </div>
</section>
