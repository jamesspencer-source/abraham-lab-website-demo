---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { newsItems } from "../../data/news";
import { siteData } from "../../data/site";
---

<BaseLayout title="News" description="Selected updates from the Abraham Lab.">
  <PageHero
    eyebrow="News"
    title="Science updates."
    description="Selected updates on publications, awards, invited talks, and institutional coverage from the Abraham Lab."
  />

  <section class="section section--utility">
    <div class="shell editorial-intro editorial-intro--split">
      <div class="section-heading reveal">
        <p class="eyebrow">News and coverage</p>
        <h2>Recent public-facing research updates.</h2>
        <p>
          Publications, awards, invited talks, and institutional coverage are collected here in chronological
          order.
        </p>
      </div>
      <div class="editorial-intro__aside reveal">
        <p class="eyebrow">Follow the lab</p>
        <div class="social-inline social-inline--stacked">
          <a href={siteData.social.x} target="_blank" rel="noreferrer">Abraham Lab on X</a>
          <a href={siteData.social.bluesky} target="_blank" rel="noreferrer">Abraham Lab on Bluesky</a>
        </div>
      </div>
    </div>

    <div class="shell ledger">
      {newsItems.map((item, index) => (
        <article class="ledger-row reveal">
          <div class="ledger-row__meta">
            <p class="eyebrow">{index === 0 ? "Latest" : item.category}</p>
            <p>{item.dateLabel}</p>
          </div>
          <div class="ledger-row__body">
            <p class="ledger-source">{item.sourceType}</p>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </div>
          <div class="ledger-row__action">
            <a class="text-link" href={item.link} target="_blank" rel="noreferrer">{item.linkLabel ?? "Open source"}</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
