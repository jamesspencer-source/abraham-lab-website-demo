---
import { withBase } from "../lib/content";

type MetaEntry = {
  label: string;
  text?: string;
  items?: string[];
  href?: string;
  hrefLabel?: string;
};

interface Props {
  index: number;
  title: string;
  lead: string;
  body: string[];
  image: string;
  imageAlt: string;
  imagePosition?: string;
  meta: MetaEntry[];
  headingTag?: "h2" | "h3";
}

const {
  index,
  title,
  lead,
  body,
  image,
  imageAlt,
  imagePosition,
  meta,
  headingTag = "h3"
} = Astro.props;

const HeadingTag = headingTag;
const indexLabel = String(index).padStart(2, "0");
---

<article class="mission-chapter reveal">
  <div class="mission-chapter__visual frame" style={imagePosition ? `--media-position: ${imagePosition};` : undefined}>
    <img src={withBase(image)} alt={imageAlt} loading="lazy" />
  </div>

  <div class="mission-chapter__body">
    <p class="mission-chapter__index">{indexLabel}</p>
    <HeadingTag>{title}</HeadingTag>
    <p class="mission-chapter__lead">{lead}</p>
    {body.map((paragraph) => <p>{paragraph}</p>)}
  </div>

  <aside class="mission-chapter__meta">
    {meta.map((item) => (
      <div class="meta-block">
        <span>{item.label}</span>
        {item.text && <p>{item.text}</p>}
        {item.items && (
          <ul class="clean-list">
            {item.items.map((entry) => <li>{entry}</li>)}
          </ul>
        )}
        {item.href && item.hrefLabel && (
          <p>
            <a class="text-link" href={item.href.startsWith("http") ? item.href : withBase(item.href)} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
              {item.hrefLabel}
            </a>
          </p>
        )}
      </div>
    ))}
  </aside>
</article>
