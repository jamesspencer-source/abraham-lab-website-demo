---
layout: layouts/base.njk
title: News
description: Selected updates from the Abraham Lab.
permalink: /news/index.html
---
<section class="page-hero page-hero--light">
  <div class="container page-hero__shell">
    <div class="page-hero__content reveal">
      <p class="eyebrow">News</p>
      <h1>Science updates.</h1>
      <p>Selected updates on publications, awards, invited talks, and institutional coverage from the Abraham Lab.</p>
    </div>
  </div>
</section>

<section class="section section--utility section--bordered">
  <div class="container news-overview">
    <div class="news-overview__copy reveal">
      <p class="eyebrow">Follow</p>
      <h2>News and institutional coverage.</h2>
      <p>
        Recent publications, awards, invited talks, and institutional coverage from the Abraham Lab are
        listed here. Follow the lab on X and Bluesky for additional updates.
      </p>
    </div>
    <aside class="news-overview__rail reveal">
      <p class="eyebrow">Follow the lab</p>
      <div class="public-updates">
        <a class="public-updates__item" href="{{ site.social.x }}" target="_blank" rel="noreferrer">
          <span class="public-updates__label">X</span>
          <span class="public-updates__text">Follow the Abraham Lab on X</span>
        </a>
        <a class="public-updates__item" href="{{ site.social.bluesky }}" target="_blank" rel="noreferrer">
          <span class="public-updates__label">Bluesky</span>
          <span class="public-updates__text">Follow the Abraham Lab on Bluesky</span>
        </a>
      </div>
    </aside>
  </div>
</section>

<section class="section section--utility">
  <div class="container update-list">
    {% for item in news %}
      <article class="update-row {% if loop.first %}update-row--latest{% endif %} reveal">
        <div class="update-row__meta">
          {% if loop.first %}
            <p class="eyebrow">Latest</p>
          {% else %}
            <p class="eyebrow">{{ item.category }}</p>
          {% endif %}
          <p>{{ item.dateLabel }}</p>
        </div>
        <div class="update-row__body">
          <p class="update-row__source">{{ item.sourceType }}</p>
          <h3>{{ item.title }}</h3>
          <p>{{ item.summary }}</p>
        </div>
        <div class="update-row__action">
          <a class="text-link" href="{{ item.link }}" target="_blank" rel="noreferrer">{{ item.linkLabel or "Open source" }}</a>
        </div>
      </article>
    {% endfor %}
  </div>
</section>
