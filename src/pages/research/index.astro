---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/content";

const destination = withBase("/publications/#research-atlas");
---

<BaseLayout
  title="Research"
  description="Published research themes from the Abraham Lab."
  canonicalPath="/publications/"
>
  <script is:inline define:vars={{ destination }}>
    if (typeof window !== "undefined") {
      window.location.replace(destination);
    }
  </script>

  <section class="page-hero page-hero--research-legacy">
    <div class="shell page-hero__grid">
      <div class="page-hero__copy reveal">
        <p class="eyebrow">Research</p>
        <h1>Research themes now live within Publications.</h1>
        <p>
          The scientific atlas for the Abraham Lab is now integrated into the publications page so that
          mechanistic themes sit directly alongside public papers, figures, and citation records.
        </p>
      </div>
      <div class="page-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Forwarding</p>
          <p><a class="text-link" href={destination}>Go to Publications</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
