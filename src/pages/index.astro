---
import BaseLayout from "../layouts/BaseLayout.astro";
import MapWidget from "../components/MapWidget.astro";
import { siteData } from "../data/site";
import { publications } from "../data/publications";
import { newsItems } from "../data/news";
import { formatMonthYear, homepageProofOnly, leadPublication, limitItems, withBase } from "../lib/content";

const homepageProof = homepageProofOnly(publications);
const leadPaper = leadPublication(publications) ?? homepageProof[0];
const supportingPapers = homepageProof.filter((item) => item.title !== leadPaper?.title).slice(0, 2);
const recentNews = limitItems(newsItems, 3);
---

<BaseLayout pageClass="page-home">
  <section class="marquee">
    <div class="marquee__shell shell">
      <div class="marquee__grid">
        <div class="marquee__copy">
          <p class="eyebrow reveal">Abraham Lab</p>
          <h1 class="reveal">{siteData.heroTitle}</h1>
          <p class="marquee__deck reveal">{siteData.heroDeck}</p>

          <div class="button-row reveal">
            <a class="button button--primary" href={withBase("/publications/")}>View publications</a>
            <a class="button button--ghost" href={withBase("/research/")}>Explore research</a>
          </div>

          <dl class="marquee__facts reveal">
            {siteData.heroFacts.map((item) => (
              <div class="marquee__fact">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="marquee__stage reveal">
          <div class="hero-mosaic">
            {siteData.heroFigures.map((item, index) => (
              <a
                class:list={["hero-mosaic__figure", `hero-mosaic__figure--${index + 1}`]}
                href={item.href}
                target="_blank"
                rel="noreferrer"
                style={item.imagePosition ? `--media-position: ${item.imagePosition};` : undefined}
              >
                <img src={withBase(item.image)} alt={item.alt} loading={index === 0 ? "eager" : "lazy"} />
                <div class="hero-mosaic__caption">
                  <p>{item.label}</p>
                  <h2>{item.title}</h2>
                  {item.note && <span>{item.note}</span>}
                </div>
              </a>
            ))}

            <aside class="hero-dossier">
              <p class="eyebrow">Recent record</p>
              <div class="hero-dossier__list">
                {homepageProof.map((item) => (
                  <article class="hero-dossier__item">
                    <p class="metadata-label">
                      {[item.journal, item.publishedAt ? formatMonthYear(item.publishedAt) : item.year].filter(Boolean).join(" | ")}
                    </p>
                    <a href={item.link} target="_blank" rel="noreferrer">{item.title}</a>
                  </article>
                ))}
              </div>
            </aside>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="institution-strip">
    <div class="shell institution-strip__grid">
      <div class="institution-strip__copy reveal">
        <p class="eyebrow">{siteData.institutionLabel}</p>
        <h2 class="institution-strip__title">
          {siteData.contact.institutionDisplayLines?.map((line) => (
            <span class={line.includes("Blavatnik Institute") ? "u-nowrap" : undefined}>{line}</span>
          ))}
        </h2>
        <p>{siteData.institutionSummary}</p>
      </div>

      <div class="institution-strip__rail">
        {siteData.affiliations.map((affiliation) => (
          <a class="institution-strip__item reveal" href={affiliation.href} target="_blank" rel="noreferrer">
            <div class="institution-strip__logo">
              <img src={withBase(affiliation.logo)} alt={affiliation.alt} loading="lazy" />
            </div>
            <div>
              <p class="institution-strip__name">{affiliation.shortName ?? affiliation.name}</p>
              {affiliation.note && <p class="institution-strip__note">{affiliation.note}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {leadPaper && (
    <section class="section section--flagship proof-feature">
      <div class="shell section-heading section-heading--split">
        <div class="reveal">
          <p class="eyebrow">Lead publication</p>
          <h2>The newest public paper anchors the homepage proof set.</h2>
        </div>
        <div class="reveal">
          <p>
            The site's first proof point is the current Cell paper on HSV-1 helicase-primase inhibition
            and replication fork assembly, followed by the latest work in arenavirus glycoprotein
            architecture and arbovirus receptor recognition.
          </p>
        </div>
      </div>

      <div class="shell editorial-feature editorial-feature--home">
        <div class="editorial-feature__copy reveal">
          <p class="eyebrow">{leadPaper.journal}</p>
          <h2>{leadPaper.title}</h2>
          <p class="editorial-feature__meta">
            {[leadPaper.publishedAt ? formatMonthYear(leadPaper.publishedAt) : undefined, leadPaper.pmid ? `PMID ${leadPaper.pmid}` : undefined].filter(Boolean).join(" / ")}
          </p>
          <p class="editorial-feature__summary">{leadPaper.summary}</p>
          <p class="citation-text">{leadPaper.citation}</p>
          <div class="button-row">
            <a class="button button--primary" href={leadPaper.link} target="_blank" rel="noreferrer">Read paper</a>
            {leadPaper.doi && <a class="button button--ghost" href={`https://doi.org/${leadPaper.doi}`} target="_blank" rel="noreferrer">DOI</a>}
          </div>
        </div>

        <div class="editorial-feature__visual reveal">
          <div class="frame editorial-feature__frame" style={leadPaper.imagePosition ? `--media-position: ${leadPaper.imagePosition};` : undefined}>
            <img src={withBase(leadPaper.image!)} alt={leadPaper.imageAlt!} loading="lazy" />
          </div>
        </div>

        <aside class="editorial-feature__rail reveal">
          <div class="metadata-stack">
            <p class="metadata-label">Venue</p>
            <p>{leadPaper.journal}</p>
          </div>
          <div class="metadata-stack">
            <p class="metadata-label">Published</p>
            <p>{leadPaper.publishedAt ? formatMonthYear(leadPaper.publishedAt) : leadPaper.year}</p>
          </div>
          {leadPaper.pmid && (
            <div class="metadata-stack">
              <p class="metadata-label">PubMed</p>
              <p>{leadPaper.pmid}</p>
            </div>
          )}
        </aside>
      </div>
    </section>
  )}

  <section class="section section--utility record-band">
    <div class="shell section-heading section-heading--split">
      <div class="reveal">
        <p class="eyebrow">Recent record</p>
        <h2>Recent publications and selected public updates.</h2>
      </div>
      <div class="reveal">
        <p>
          The homepage stays concise. Broader mechanistic framing lives on the Research page, while the
          publication record and public updates remain directly linked to source material.
        </p>
      </div>
    </div>

    <div class="shell record-band__grid">
      <section class="ledger-panel reveal">
        <div class="ledger-panel__header">
          <p class="eyebrow">Recent publications</p>
          <a class="text-link" href={withBase("/publications/")}>Publication record</a>
        </div>
        <div class="ledger-list">
          {supportingPapers.map((item) => (
            <article class="ledger-item">
              <p class="ledger-item__meta">
                {[item.journal, item.publishedAt ? formatMonthYear(item.publishedAt) : item.year].filter(Boolean).join(" / ")}
              </p>
              <h3><a href={item.link} target="_blank" rel="noreferrer">{item.title}</a></h3>
              {item.summary && <p>{item.summary}</p>}
            </article>
          ))}
        </div>
      </section>

      <section class="ledger-panel reveal">
        <div class="ledger-panel__header">
          <p class="eyebrow">Selected updates</p>
          <a class="text-link" href={withBase("/news/")}>All updates</a>
        </div>
        <div class="ledger-list">
          {recentNews.map((item) => (
            <article class="ledger-item">
              <p class="ledger-item__meta">{formatMonthYear(item.date)} / {item.category}</p>
              <h3><a href={item.link} target="_blank" rel="noreferrer">{item.title}</a></h3>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
        <div class="ledger-panel__footer">
          <p class="metadata-label">Social</p>
          <a class="text-link" href={siteData.social.x} target="_blank" rel="noreferrer">Abraham Lab on X</a>
        </div>
      </section>
    </div>
  </section>

  <section class="section section--utility location-band">
    <div class="shell location-band__grid">
      <div class="location-band__copy reveal">
        <p class="eyebrow">Location</p>
        <h2>{siteData.contact.homeLocationLabel}</h2>
        <p class="location-band__institution">
          <span>{siteData.contact.institutionDisplayLines?.[0]}</span>
          <span class="u-nowrap">{siteData.contact.institutionDisplayLines?.[1]}</span>
        </p>
        <p>For collaborations, speaking requests, and administrative inquiries.</p>
        <div class="location-list">
          {siteData.contact.addressLines.map((line) => <p>{line}</p>)}
        </div>
        <div class="button-row">
          <a class="button button--primary" href={`mailto:${siteData.contact.email}`}>Email Jonathan Abraham</a>
          <a class="button button--ghost" href={withBase("/contact/")}>Contact page</a>
        </div>
      </div>

      <MapWidget
        mode="home"
        eyebrow="Campus map"
        description="Harvard Medical School campus"
      />
    </div>
  </section>
</BaseLayout>
