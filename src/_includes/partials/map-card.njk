<aside class="map-card {{ mapCardClass or '' }} reveal">
  <div class="map-card__header">
    <p class="eyebrow">{{ mapEyebrow or "Location" }}</p>
    <h3>{{ site.contact.mapDisplayName }}</h3>
    {% if mapDescription %}
      <p>{{ mapDescription }}</p>
    {% endif %}
  </div>

  <a
    class="map-card__frame"
    href="{{ site.contact.mapUrl }}"
    target="_blank"
    rel="noreferrer"
    aria-label="Open the Abraham Lab location in Google Maps"
  >
    <div class="map-card__tiles" aria-hidden="true">
      {% for tile in site.contact.mapPreviewTiles %}
        <img class="map-card__tile" src="{{ tile | withBase }}" alt="" loading="lazy" />
      {% endfor %}
    </div>
    <div class="map-card__marker">
      <span class="map-card__marker-dot"></span>
      <span class="map-card__marker-label">{{ site.contact.homeLocationLabel }}</span>
    </div>
  </a>

  <div class="map-card__footer">
    <a class="text-link" href="{{ site.contact.mapUrl }}" target="_blank" rel="noreferrer">Open in Google Maps</a>
  </div>
</aside>
