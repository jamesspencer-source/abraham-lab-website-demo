---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ResearchChapter from "../../components/ResearchChapter.astro";
import { researchPrograms } from "../../data/research";
---

<BaseLayout
  title="Research"
  description="Research themes in viral entry, antiviral antibodies, and viral polymerase biology at the Abraham Lab."
>
  <section class="interior-hero interior-hero--research">
    <div class="shell interior-hero__grid">
      <div class="interior-hero__copy reveal">
        <p class="eyebrow">Research</p>
        <h1>Three scientific programs tied together by mechanism, structure, and public evidence.</h1>
        <p>
          The Abraham Lab studies viral entry, neutralization, and genome replication at the level of receptor
          recognition, glycoprotein organization, and polymerase architecture. Across the program, structural and
          functional experiments are used to identify points of therapeutic vulnerability in medically important
          viruses.
        </p>
      </div>

      <div class="interior-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Core systems</p>
          <ul class="clean-list metadata-list">
            <li>alphaviruses</li>
            <li>arenaviruses</li>
            <li>henipaviruses</li>
            <li>herpesviruses</li>
          </ul>
        </div>
        <div class="metadata-stack">
          <p class="metadata-label">Core methods</p>
          <ul class="clean-list metadata-list">
            <li>cryo-EM and crystallography</li>
            <li>protein biochemistry</li>
            <li>functional virology</li>
            <li>receptor and antibody analysis</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--flagship">
    <div class="shell research-chapter-list">
      {researchPrograms.map((item, index) => (
        <ResearchChapter
          index={index + 1}
          title={item.title}
          keyQuestion={item.keyQuestion}
          importance={item.importance}
          summary={item.summary}
          paragraphs={item.paragraphs}
          systems={item.systems}
          methods={item.methods}
          papers={item.papers}
          image={item.image}
          imageAlt={item.imageAlt}
          imagePosition={item.imagePosition}
          reverse={index % 2 === 1}
          headingTag="h2"
        />
      ))}
    </div>
  </section>

  <section class="section section--utility methods-band">
    <div class="shell methods-band__grid">
      <div class="reveal">
        <p class="eyebrow">Program method</p>
        <h2>Integrated structure, mechanism, and infection biology.</h2>
      </div>
      <div class="reveal">
        <p>
          The laboratory combines discovery genetics, structural biology, protein science, and infection-focused
          functional experiments. The goal is not simply to describe viral proteins, but to identify mechanisms
          that explain tropism, neutralization, immune escape, replication, and antiviral failure.
        </p>
      </div>
      <div class="reveal methods-band__rail">
        <p>CRISPR-based discovery</p>
        <p>Biophysics and protein biochemistry</p>
        <p>Cryo-EM and crystallography</p>
        <p>Cellular infection assays</p>
      </div>
    </div>
  </section>
</BaseLayout>
