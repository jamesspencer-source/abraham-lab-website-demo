---
import { siteData } from "../data/site";
import { withBase } from "../lib/content";

interface Props {
  eyebrow?: string;
  description?: string;
  mode?: "home" | "contact";
}

const { eyebrow = "Location", description, mode = "home" } = Astro.props;
---

<aside class:list={["map-widget", `map-widget--${mode}`, "reveal"]}>
  <div class="map-widget__media frame">
    <img src={withBase(siteData.contact.mapPreviewImage)} alt={siteData.contact.mapPreviewAlt} loading="lazy" />
    <div class="map-widget__pin" aria-hidden="true"></div>
  </div>

  <div class="map-widget__card">
    <p class="eyebrow">{eyebrow}</p>
    <h3>{siteData.contact.mapDisplayName}</h3>
    {description && <p>{description}</p>}
    <div class="map-widget__address">
      <p>{siteData.contact.mapBuilding}</p>
      <p>{siteData.contact.mapContext}</p>
    </div>
    <div class="map-widget__actions">
      <a class="text-link" href={siteData.contact.mapUrl} target="_blank" rel="noreferrer">Google Maps</a>
      {siteData.contact.appleMapUrl && (
        <a class="text-link" href={siteData.contact.appleMapUrl} target="_blank" rel="noreferrer">Apple Maps</a>
      )}
    </div>
  </div>
</aside>
