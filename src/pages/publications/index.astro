---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { publications } from "../../data/publications";
import { featuredOnly, formatMonthYear, groupPublicationsByYear, leadPublication, withBase } from "../../lib/content";

const featuredPublications = featuredOnly(publications);
const leadPaper = leadPublication(publications) ?? featuredPublications[0];
const groupedPublications = groupPublicationsByYear(publications);
---

<BaseLayout title="Publications" description="Selected and archived Abraham Lab publications.">
  <section class="page-hero page-hero--publications">
    <div class="shell page-hero__grid">
      <div class="page-hero__copy reveal">
        <p class="eyebrow">Publications</p>
        <h1>Publication record in entry biology, glycoprotein structure, and viral replication.</h1>
        <p>
          The publication record spans receptor recognition, glycoprotein architecture, antibody-mediated
          neutralization, and replication machinery, with an emphasis on mechanistic questions relevant to
          antiviral design and emerging infectious disease.
        </p>
      </div>
      <div class="page-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Recent venues</p>
          <ul class="clean-list metadata-list">
            <li>Cell</li>
            <li>Nature Microbiology</li>
            <li>Nature Communications</li>
            <li>Science</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {leadPaper && (
    <section class="section section--flagship proof-feature proof-feature--interior">
      <div class="shell editorial-feature editorial-feature--interior">
        <div class="editorial-feature__copy reveal">
          <p class="eyebrow">Lead paper</p>
          <h2>{leadPaper.title}</h2>
          <p class="editorial-feature__meta">
            {[leadPaper.journal, leadPaper.publishedAt ? formatMonthYear(leadPaper.publishedAt) : undefined, leadPaper.pmid ? `PMID ${leadPaper.pmid}` : undefined].filter(Boolean).join(" / ")}
          </p>
          <p class="editorial-feature__summary">{leadPaper.summary}</p>
          <p class="citation-text">{leadPaper.citation}</p>
          <div class="button-row">
            <a class="button button--primary" href={leadPaper.link} target="_blank" rel="noreferrer">Read paper</a>
            {leadPaper.doi && <a class="button button--ghost" href={`https://doi.org/${leadPaper.doi}`} target="_blank" rel="noreferrer">DOI</a>}
          </div>
        </div>

        <div class="editorial-feature__visual reveal">
          <div class="frame editorial-feature__frame" style={leadPaper.imagePosition ? `--media-position: ${leadPaper.imagePosition};` : undefined}>
            <img src={withBase(leadPaper.image!)} alt={leadPaper.imageAlt!} loading="lazy" />
          </div>
        </div>

        <aside class="editorial-feature__rail reveal">
          <p class="metadata-label">Selected papers</p>
          <div class="reference-list">
            {featuredPublications.filter((item) => item.title !== leadPaper.title).slice(0, 4).map((item) => (
              <article class="reference-card">
                <p class="reference-card__meta">
                  {[item.journal ?? "Publication", item.year].join(" / ")}
                </p>
                <a class="reference-card__title" href={item.link} target="_blank" rel="noreferrer">{item.title}</a>
                <p class="reference-card__note">{item.citation}</p>
              </article>
            ))}
          </div>
        </aside>
      </div>
    </section>
  )}

  <section class="section section--utility archive-band">
    <div class="shell section-heading section-heading--compact">
      <div class="reveal">
        <p class="eyebrow">Archive</p>
        <h2>Year-grouped citation ledger.</h2>
      </div>
    </div>

    <div class="shell archive-list">
      {groupedPublications.map((yearGroup) => (
        <section class="archive-group reveal">
          <div class="archive-group__year">
            <h3>{yearGroup.year}</h3>
          </div>
          <ol class="clean-list archive-group__entries">
            {yearGroup.entries.map((item) => (
              <li>
                <a href={item.link} target="_blank" rel="noreferrer">{item.title}</a>
                <p>
                  {[item.journal, item.publishedAt ? formatMonthYear(item.publishedAt) : undefined, item.pmid ? `PMID ${item.pmid}` : undefined].filter(Boolean).join(" | ")}
                </p>
                <p>{item.citation}</p>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
