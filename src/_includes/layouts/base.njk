<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if page.url == "/" %}{{ site.fullName }}{% else %}{{ title }} | {{ site.fullName }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="theme-color" content="#0b0f14" />
    <meta property="og:title" content="{% if page.url == "/" %}{{ site.fullName }}{% else %}{{ title }} | {{ site.fullName }}{% endif %}" />
    <meta property="og:description" content="{{ description or site.description }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ site.url }}{{ page.url | withBase }}" />
    <meta property="og:site_name" content="{{ site.fullName }}" />
    <meta property="og:image" content="{{ site.url }}{{ (site.heroImage or '/assets/images/research/hero-emergingvirus.jpg') | withBase }}" />
    <link rel="canonical" href="{{ site.url }}{{ page.url | withBase }}" />
    <link rel="icon" href="{{ '/assets/images/brands/favicon.svg' | withBase }}" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ '/assets/css/styles.css' | withBase }}" />
  </head>
  <body class="{{ bodyClass or '' }}">
    {% include "partials/header.njk" %}
    <main id="main-content">
      {{ content | safe }}
    </main>
    {% include "partials/footer.njk" %}
    <script type="module" src="{{ '/assets/js/site.js' | withBase }}"></script>
  </body>
</html>
