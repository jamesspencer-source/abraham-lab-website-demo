---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { jonathanProfile } from "../../data/jonathan";
import { publications } from "../../data/publications";
import { featuredOnly, limitItems, withBase } from "../../lib/content";

const selectedPublications = limitItems(featuredOnly(publications), 4);
---

<BaseLayout title="Jonathan Abraham" description="Profile of Jonathan Abraham, M.D., Ph.D.">
  <PageHero
    eyebrow="Jonathan Abraham"
    title={jonathanProfile.name}
    description={`${jonathanProfile.title} · ${jonathanProfile.secondaryTitle}`}
  />

  <section class="section section--flagship">
    <div class="shell profile-grid">
      <div class="profile-grid__portrait frame reveal" style={jonathanProfile.portraitPosition ? `--media-position: ${jonathanProfile.portraitPosition};` : undefined}>
        <img src={withBase(jonathanProfile.portrait)} alt={jonathanProfile.portraitAlt} loading="lazy" />
      </div>

      <div class="profile-grid__body reveal">
        <p class="eyebrow">Scientific biography</p>
        <p class="feature-lead">{jonathanProfile.overview}</p>
        {jonathanProfile.biography.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section section--soft section--utility">
    <div class="shell fact-grid">
      <article class="utility-panel reveal">
        <div class="utility-panel__header">
          <p class="eyebrow">Appointments</p>
        </div>
        <ul class="clean-list fact-list">
          {jonathanProfile.appointments.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="utility-panel reveal">
        <div class="utility-panel__header">
          <p class="eyebrow">Distinctions</p>
        </div>
        <ul class="clean-list fact-list">
          {jonathanProfile.distinctions.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="utility-panel reveal">
        <div class="utility-panel__header">
          <p class="eyebrow">Research focus</p>
        </div>
        <ul class="clean-list fact-list">
          {jonathanProfile.focusAreas.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section section--utility">
    <div class="shell section-heading reveal">
      <p class="eyebrow">Representative work</p>
      <h2>Selected publications aligned with the laboratory program.</h2>
    </div>

    <div class="shell ledger ledger--citations">
      {selectedPublications.map((item) => (
        <article class="ledger-row reveal">
          <div class="ledger-row__meta">
            <p class="eyebrow">{item.year}</p>
          </div>
          <div class="ledger-row__body">
            <h3>{item.title}</h3>
            {item.summary && <p>{item.summary}</p>}
            <p class="citation-text">{item.citation}</p>
          </div>
          <div class="ledger-row__action">
            <a class="text-link" href={item.link} target="_blank" rel="noreferrer">Read paper</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
