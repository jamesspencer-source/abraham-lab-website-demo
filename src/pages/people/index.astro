---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { peopleData } from "../../data/people";
import { groupPeople, withBase } from "../../lib/content";

const groupedPeople = groupPeople(peopleData.currentMembers);
const leadership = groupedPeople.find((group) => group.label === "Leadership");
const remainingGroups = groupedPeople.filter((group) => group.label !== "Leadership");
const totalAlumni = peopleData.alumni.reduce((total, group) => total + group.entries.length, 0);
const anchorFor = (label: string) =>
  label
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const directoryIndex = [
  leadership ? { label: leadership.label, count: leadership.entries.length, id: anchorFor(leadership.label) } : null,
  ...remainingGroups.map((group) => ({
    label: group.label,
    count: group.entries.length,
    id: anchorFor(group.label)
  })),
  { label: "Alumni", count: totalAlumni, id: "alumni" }
].filter(Boolean);
---

<BaseLayout
  title="People"
  description="Current members and alumni of the Abraham Lab."
  socialImage={leadership?.entries[0]?.image ?? peopleData.currentMembers[0]?.image}
>
  <section class="page-hero page-hero--people">
    <div class="shell page-hero__grid">
      <div class="page-hero__copy reveal">
        <p class="eyebrow">People</p>
        <h1>Faculty, fellows, students, and operations leadership of the Abraham Lab.</h1>
        <p>
          Current members are grouped by role. Alumni are listed below.
        </p>
      </div>
      <div class="page-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Current members</p>
          <p>{peopleData.currentMembers.length}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--utility directory-controls-band">
    <div class="shell directory-controls">
      <div class="directory-index">
        {directoryIndex.map((item) => (
          item && (
            <a class="directory-index__chip reveal" href={`#${item.id}`}>
              <span>{item.label}</span>
              <strong>{item.count}</strong>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  {leadership && (
    <section
      class="section section--flagship"
      id={anchorFor(leadership.label)}
      data-directory-group={leadership.label}
    >
      <div class="shell directory-lead">
        {leadership.entries.map((person) => (
          <article class="directory-lead__row reveal">
            <div class="directory-lead__media frame" style={person.imagePosition ? `--media-position: ${person.imagePosition};` : undefined}>
              <img src={withBase(person.image)} alt={person.imageAlt} loading="lazy" />
            </div>
            <div class="directory-lead__body">
              <p class="eyebrow">Leadership</p>
              <h2>{person.name}</h2>
              <p class="directory-lead__title">{person.title}</p>
              {(person.roleSummary ?? person.note) && <p>{person.roleSummary ?? person.note}</p>}
              {person.expertiseTags?.length ? (
                <div class="tag-list">
                  {person.expertiseTags.map((tag) => <span class="tag-chip">{tag}</span>)}
                </div>
              ) : null}
              <div class="button-row">
                <a class="button button--primary" href={withBase("/jonathan-abraham/")}>Profile</a>
                <a class="button button--ghost" href={withBase("/contact/")}>Contact</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section section--utility">
    <div class="shell directory-groups">
      {remainingGroups.map((group) => (
        <section class="directory-group reveal" id={anchorFor(group.label)} data-directory-group={group.label}>
          <div class="directory-group__header">
            <div>
              <p class="eyebrow">Current members</p>
              <h2>{group.label}</h2>
            </div>
            <p class="directory-group__count">{group.entries.length} people</p>
          </div>

          <div class="directory-grid">
            {group.entries.map((person) => (
              <article class="directory-row">
                <div class="directory-row__media frame" style={person.imagePosition ? `--media-position: ${person.imagePosition};` : undefined}>
                  <img src={withBase(person.image)} alt={person.imageAlt} loading="lazy" />
                </div>
                <div class="directory-row__body">
                  <h3>{person.name}</h3>
                  <p class="directory-row__title">{person.title}</p>
                  {(person.roleSummary ?? person.note) && <p>{person.roleSummary ?? person.note}</p>}
                  {person.expertiseTags?.length ? (
                    <div class="tag-list">
                      {person.expertiseTags.map((tag) => <span class="tag-chip">{tag}</span>)}
                    </div>
                  ) : null}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="section section--utility alumni-band" id="alumni" data-directory-group="alumni">
    <div class="shell section-heading section-heading--compact">
      <div class="reveal">
        <p class="eyebrow">Alumni</p>
        <h2>Past members.</h2>
      </div>
    </div>

    <div class="shell alumni-shell">
      {peopleData.alumni.map((group) => (
        <section class="alumni-group reveal">
          <div class="directory-group__header">
            <h3>{group.label}</h3>
            <p class="directory-group__count">{group.entries.length} entries</p>
          </div>
          <div class="alumni-list">
            {group.entries.map((entry) => (
              <div class="alumni-row">
                <p class="alumni-row__name">{entry.name}</p>
                <p class="alumni-row__destination">{entry.destination ?? ""}</p>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
