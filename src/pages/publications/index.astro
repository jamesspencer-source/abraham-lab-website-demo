---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { publications } from "../../data/publications";
import { featuredOnly, formatMonthYear, groupPublicationsByYear, withBase } from "../../lib/content";

const featuredPublications = featuredOnly(publications);
const leadPublication = featuredPublications[0];
const groupedPublications = groupPublicationsByYear(publications);
---

<BaseLayout title="Publications" description="Selected and archived Abraham Lab publications.">
  <section class="interior-hero interior-hero--publications">
    <div class="shell interior-hero__grid">
      <div class="interior-hero__copy reveal">
        <p class="eyebrow">Publications</p>
        <h1>Selected work in entry biology, antiviral antibodies, and viral replication.</h1>
        <p>
          The publication record spans receptor recognition, glycoprotein architecture, antibody-mediated
          neutralization, and replication machinery, with an emphasis on mechanistic questions that matter for
          antiviral design and emerging infectious disease.
        </p>
      </div>
      <div class="interior-hero__rail reveal">
        <div class="metadata-stack">
          <p class="metadata-label">Recent venues</p>
          <ul class="clean-list metadata-list">
            <li>Cell</li>
            <li>Nature Microbiology</li>
            <li>Nature Communications</li>
            <li>Science</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {leadPublication && (
    <section class="section section--flagship publication-band publication-band--interior">
      <div class="shell publication-band__grid">
        <div class="publication-band__body reveal">
          <p class="eyebrow">Lead paper</p>
          <h2>{leadPublication.title}</h2>
          <p class="publication-band__meta">
            {[leadPublication.journal, leadPublication.publishedAt ? formatMonthYear(leadPublication.publishedAt) : undefined, leadPublication.pmid ? `PMID ${leadPublication.pmid}` : undefined].filter(Boolean).join(" | ")}
          </p>
          <p class="publication-band__summary">{leadPublication.summary}</p>
          <p class="citation-text">{leadPublication.citation}</p>
          <div class="button-row">
            <a class="button button--primary" href={leadPublication.link} target="_blank" rel="noreferrer">Read paper</a>
            {leadPublication.doi && <a class="button button--ghost" href={`https://doi.org/${leadPublication.doi}`} target="_blank" rel="noreferrer">DOI</a>}
          </div>
        </div>

        <div class="publication-band__visual reveal">
          <div class="publication-band__image frame" style={leadPublication.imagePosition ? `--media-position: ${leadPublication.imagePosition};` : undefined}>
            <img src={withBase(leadPublication.image!)} alt={leadPublication.imageAlt!} loading="lazy" />
          </div>
        </div>

        <aside class="publication-band__rail reveal">
          <p class="metadata-label">Selected papers</p>
          <div class="reference-list">
            {featuredPublications.slice(1).map((item) => (
              <article class="reference-card">
                <p class="reference-card__meta">
                  {[item.journal ?? "Publication", item.year].join(" | ")}
                </p>
                <a class="reference-card__title" href={item.link} target="_blank" rel="noreferrer">{item.title}</a>
                <p class="reference-card__note">{item.citation}</p>
              </article>
            ))}
          </div>
        </aside>
      </div>
    </section>
  )}

  <section class="section section--utility archive-band">
    <div class="shell page-section__header page-section__header--compact">
      <div class="reveal">
        <p class="eyebrow">Archive</p>
        <h2>Year-grouped publication record.</h2>
      </div>
    </div>

    <div class="shell archive-list">
      {groupedPublications.map((yearGroup) => (
        <section class="archive-group reveal">
          <div class="archive-group__year">
            <h3>{yearGroup.year}</h3>
          </div>
          <ol class="clean-list archive-group__entries">
            {yearGroup.entries.map((item) => (
              <li>
                <a href={item.link} target="_blank" rel="noreferrer">{item.title}</a>
                <p>
                  {[item.journal, item.publishedAt ? formatMonthYear(item.publishedAt) : undefined, item.pmid ? `PMID ${item.pmid}` : undefined].filter(Boolean).join(" | ")}
                </p>
                <p>{item.citation}</p>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
