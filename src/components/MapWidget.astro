---
import { siteData } from "../data/site";

interface Props {
  eyebrow?: string;
  description?: string;
  mode?: "home" | "contact";
}

const { eyebrow = "Location", description, mode = "home" } = Astro.props;
---

<aside class:list={["utility-panel", "map-widget", `map-widget--${mode}`, "reveal"]}>
  <div class="utility-panel__header">
    <p class="eyebrow">{eyebrow}</p>
    <h3>{siteData.contact.mapDisplayName}</h3>
    {description && <p>{description}</p>}
  </div>

  <div class="map-widget__frame">
    <iframe
      src={siteData.contact.mapEmbedUrl}
      title={`Map showing ${siteData.contact.mapDisplayName}`}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

  <div class="utility-panel__footer">
    <a class="text-link" href={siteData.contact.mapUrl} target="_blank" rel="noreferrer">Open in Google Maps</a>
  </div>
</aside>
