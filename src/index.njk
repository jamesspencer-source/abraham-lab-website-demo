---
layout: layouts/base.njk
title: Abraham Lab
description: The Abraham Lab studies viral entry, antibody neutralization, and polymerase function through structural biology and molecular virology.
bodyClass: page-home
---
{% set featuredPublications = publications | featuredOnly %}
{% set leadPublication = featuredPublications[0] %}
{% set recentNews = news | limit(4) %}

<section class="hero hero--mission">
  <div class="hero__media">
    <img
      src="/assets/images/research/hero-emergingvirus.jpg"
      alt="Illustrated structural virology composition highlighting viral surface proteins and host receptor engagement."
    />
  </div>
  <div class="hero__scrim"></div>
  <div class="container hero__grid">
    <div class="hero__copy">
      <p class="eyebrow reveal">Structural virology | molecular virology | biophysics</p>
      <h1 class="reveal">{{ site.heroTitle }}</h1>
      <p class="hero__deck reveal">{{ site.heroDeck }}</p>
      <div class="hero__actions reveal">
        <a class="button button--primary" href="/research/">Research</a>
        <a class="button button--secondary" href="/publications/">Publications</a>
      </div>
    </div>
    <div class="hero__rail">
      <section class="hero__panel reveal">
        <p class="eyebrow">Mission areas</p>
        <ul class="clean-list hero__list">
          {% for item in site.heroDetails %}
            <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </section>
      <section class="hero__panel reveal">
        <p class="eyebrow">Approach</p>
        <p>{{ site.heroApproach }}</p>
      </section>
    </div>
  </div>
</section>

<section class="institution-strip">
  <div class="container institution-strip__grid reveal">
    <div class="institution-strip__copy">
      <p class="eyebrow">Institutional base</p>
      <h2>Harvard Medical School and Howard Hughes Medical Institute.</h2>
      <p>
        The laboratory is based in the Department of Microbiology at Harvard Medical School and
        operates within a research environment oriented around mechanistic science with direct
        biomedical consequence.
      </p>
    </div>
    <div class="institution-strip__logos">
      {% for affiliation in site.affiliations %}
        <a href="{{ affiliation.href }}" target="_blank" rel="noreferrer" aria-label="{{ affiliation.name }}">
          <img src="{{ affiliation.logo }}" alt="{{ affiliation.alt }}" loading="lazy" />
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--bordered">
  <div class="container section-heading reveal">
    <p class="eyebrow">Scientific program</p>
    <h2>Mechanistic work anchored in problems with direct therapeutic relevance.</h2>
    <p>
      The lab studies how viruses recognize host cells, how antibodies block infection, and how viral
      polymerases execute genome replication. Across these areas, the unifying aim is to resolve the
      molecular determinants that govern vulnerability to intervention.
    </p>
  </div>

  <div class="container mission-list">
    {% for item in research %}
      <article class="mission-module reveal">
        <div class="mission-module__index">{{ ("0" + loop.index) if loop.index < 10 else loop.index }}</div>
        <div class="mission-module__body">
          <p class="mission-module__lead">{{ item.lead }}</p>
          <h3>{{ item.title }}</h3>
          <p>{{ item.summary }}</p>
        </div>
        <div class="mission-module__meta">
          <p><span>Systems</span>{{ item.systems | join(", ") }}</p>
          <p><span>Methods</span>{{ item.methods | join(", ") }}</p>
        </div>
        <div class="mission-module__link">
          <a class="text-link" href="/research/">Explore the program</a>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<section class="section section--offwhite">
  <div class="container section-heading reveal">
    <p class="eyebrow">Selected publications</p>
    <h2>Recent papers across receptor biology, antibody action, and viral replication.</h2>
  </div>

  {% if leadPublication %}
    <div class="container editorial-feature reveal">
      <div class="editorial-feature__visual">
        <img src="{{ leadPublication.image }}" alt="{{ leadPublication.imageAlt }}" loading="lazy" />
      </div>
      <div class="editorial-feature__body">
        <p class="eyebrow">Lead paper</p>
        <h3>{{ leadPublication.title }}</h3>
        <p class="editorial-feature__summary">{{ leadPublication.summary }}</p>
        <p class="publication-meta">
          {{ leadPublication.year }}{% if leadPublication.doi %} | {{ leadPublication.doi }}{% endif %}
        </p>
        <p class="citation-text">{{ leadPublication.citation }}</p>
        <a class="button button--primary" href="{{ leadPublication.link }}" target="_blank" rel="noreferrer">Read publication</a>
      </div>
      <aside class="editorial-feature__rail">
        <p class="eyebrow">Selected papers</p>
        <ol class="citation-rail">
          {% for item in featuredPublications %}
            {% if not loop.first %}
              <li class="citation-rail__item">
                <p class="citation-rail__meta">{{ item.year }}</p>
                <div>
                  <a href="{{ item.link }}" target="_blank" rel="noreferrer">{{ item.title }}</a>
                  <p>{{ item.citation }}</p>
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ol>
      </aside>
    </div>
  {% endif %}
</section>

<section class="section section--bordered">
  <div class="container section-heading reveal">
    <p class="eyebrow">News</p>
    <h2>Science updates from the lab.</h2>
  </div>

  <div class="container update-list">
    {% for item in recentNews %}
      <article class="update-row reveal">
        <div class="update-row__meta">
          <p class="eyebrow">{{ item.category }}</p>
          <p>{{ item.dateLabel }}</p>
        </div>
        <div class="update-row__body">
          <h3>{{ item.title }}</h3>
          <p>{{ item.summary }}</p>
        </div>
        <div class="update-row__action">
          <a class="text-link" href="{{ item.link }}" target="_blank" rel="noreferrer">Open source</a>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<section class="section section--offwhite">
  <div class="container action-band reveal">
    <div>
      <p class="eyebrow">Contact</p>
      <h2>Scientific inquiries, collaborations, and speaking requests.</h2>
      <p>{{ site.contact.department }}</p>
      <p>{{ site.contact.addressLines | join(", ") }}</p>
    </div>
    <div class="action-band__actions">
      <a class="button button--primary" href="mailto:{{ site.contact.email }}">Email Jonathan Abraham</a>
      <a class="button button--secondary" href="/contact/">Contact details</a>
    </div>
  </div>
</section>
