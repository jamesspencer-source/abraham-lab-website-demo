<aside class="map-card {{ mapCardClass or '' }} reveal">
  <div class="map-card__header">
    <p class="eyebrow">{{ mapEyebrow or "Location" }}</p>
    <h3>{{ site.contact.mapDisplayName }}</h3>
    {% if mapDescription %}
      <p>{{ mapDescription }}</p>
    {% endif %}
  </div>

  <div class="map-card__frame">
    <iframe
      class="map-card__embed"
      src="{{ site.contact.mapEmbedUrl }}"
      title="Map showing {{ site.contact.mapDisplayName }}"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

  <div class="map-card__meta">
    <div class="map-card__meta-item">
      <span>Campus</span>
      <p>{{ site.contact.homeLocationLabel }}</p>
    </div>
    <div class="map-card__meta-item">
      <span>Building</span>
      <p>{{ site.contact.mapBuilding }}</p>
    </div>
  </div>

  <div class="map-card__footer">
    <a class="text-link" href="{{ site.contact.mapUrl }}" target="_blank" rel="noreferrer">Open in Google Maps</a>
    <p>Map data from OpenStreetMap.</p>
  </div>
</aside>
