---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteData } from "../data/site";
import { withBase } from "../lib/content";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
  canonicalPath?: string;
  socialImage?: string;
}

const { title, description, pageClass, canonicalPath, socialImage: socialImagePath } = Astro.props;
const pageTitle = title ? `${title} | ${siteData.fullName}` : siteData.fullName;
const metaDescription = description ?? siteData.description;
const canonicalTarget = canonicalPath ?? Astro.url.pathname;
const canonical = new URL(canonicalTarget, siteData.url).toString();
const socialImage = new URL(withBase(socialImagePath ?? siteData.heroFigures[0].image), siteData.url).toString();
const themeDefaultMode = siteData.theme.defaultMode;
const themeColorLight = "#f6f7f8";
const themeColorDark = "#15191c";
const themeColorHero = "#0c0f11";
const isHomePage = pageClass === "page-home";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content={isHomePage ? themeColorHero : themeColorLight} />
    <script is:inline define:vars={{ themeDefaultMode, themeColorLight, themeColorDark, themeColorHero, isHomePage }}>
      (() => {
        const root = document.documentElement;
        root.classList.add("js");
        const themeMeta = document.querySelector('meta[name="theme-color"]');
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = themeDefaultMode === "system" ? (prefersDark ? "dark" : "light") : "light";
        root.dataset.theme = theme;
        root.style.colorScheme = theme;
        if (themeMeta) {
          themeMeta.setAttribute("content", isHomePage ? themeColorHero : (theme === "dark" ? themeColorDark : themeColorLight));
        }
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteData.fullName} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={withBase("/assets/images/brands/favicon.svg")} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={["site-body", pageClass]}>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline define:vars={{ themeDefaultMode, themeColorLight, themeColorDark, themeColorHero }}>
      const navToggle = document.querySelector(".nav-toggle");
      const nav = document.querySelector(".site-nav");
      const root = document.documentElement;
      const body = document.body;
      const hero = document.querySelector(".page-home .marquee");
      const header = document.querySelector(".site-header");
      const themeMeta = document.querySelector('meta[name="theme-color"]');
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
      const resolveTheme = () => {
        return prefersDark.matches ? "dark" : "light";
      };
      const syncThemeColor = () => {
        if (!themeMeta) return;
        const theme = root.dataset.theme === "dark" ? "dark" : "light";
        const heroActive = body.classList.contains("page-home") && !body.classList.contains("home-hero-past");
        themeMeta.setAttribute("content", heroActive ? themeColorHero : (theme === "dark" ? themeColorDark : themeColorLight));
      };
      const applyTheme = (theme) => {
        root.dataset.theme = theme;
        root.style.colorScheme = theme;
        syncThemeColor();
      };
      const syncHeroHeader = () => {
        if (!(hero instanceof HTMLElement) || !(header instanceof HTMLElement)) {
          body.classList.remove("home-hero-past");
          syncThemeColor();
          return;
        }
        const threshold = Math.max(hero.offsetHeight - header.offsetHeight - 24, 0);
        body.classList.toggle("home-hero-past", window.scrollY > threshold);
        syncThemeColor();
      };

      applyTheme(resolveTheme());
      syncHeroHeader();

      const syncSystemTheme = () => {
        if (themeDefaultMode === "system") {
          applyTheme(prefersDark.matches ? "dark" : "light");
        }
      };

      if ("addEventListener" in prefersDark) {
        prefersDark.addEventListener("change", syncSystemTheme);
      } else if ("addListener" in prefersDark) {
        prefersDark.addListener(syncSystemTheme);
      }

      if (navToggle && nav) {
        const closeNav = () => {
          nav.classList.remove("is-open");
          navToggle.setAttribute("aria-expanded", "false");
        };

        navToggle.addEventListener("click", () => {
          const isOpen = nav.classList.toggle("is-open");
          navToggle.setAttribute("aria-expanded", String(isOpen));
        });

        nav.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", closeNav);
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeNav();
          }
        });

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Node)) return;
          if (!nav.contains(target) && !navToggle.contains(target)) {
            closeNav();
          }
        });

        window.addEventListener("resize", () => {
          if (window.innerWidth > 1160) {
            closeNav();
          }
        });
      }

      if (body.classList.contains("page-home")) {
        window.addEventListener("scroll", syncHeroHeader, { passive: true });
        window.addEventListener("resize", syncHeroHeader);
      }

      const revealNodes = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window && revealNodes.length) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16, rootMargin: "0px 0px -8% 0px" }
        );

        revealNodes.forEach((node) => observer.observe(node));
      } else {
        revealNodes.forEach((node) => node.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
