---
import { siteData } from "../data/site";
import { withBase } from "../lib/content";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const normalizePath = (value: string) =>
  value.replace(/index\.html$/, "").replace(/\/+$/, "/") || "/";

const current = normalizePath(currentPath);

const isActive = (href: string) => {
  const target = normalizePath(withBase(href));
  return href === "/" ? current === target : current.startsWith(target);
};
---

<a class="skip-link" href="#main-content">Skip to main content</a>
<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href={withBase("/")} aria-label={`${siteData.fullName} home`}>
      <span class="brand__eyebrow">Harvard Medical School / Microbiology / HHMI</span>
      <span class="brand__name">{siteData.name}</span>
    </a>

    <div class="site-header__controls">
      <nav id="site-nav" class="site-nav" aria-label="Primary">
        {siteData.nav.map((item) => (
          <a class="site-nav__link" href={withBase(item.href)} aria-current={isActive(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))}
      </nav>

      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        Menu
      </button>
    </div>
  </div>
</header>
