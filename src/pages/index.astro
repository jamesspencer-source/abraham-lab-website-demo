---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteData } from "../data/site";
import { publications } from "../data/publications";
import { newsItems } from "../data/news";
import { peopleData } from "../data/people";
import { formatMonthYear, groupPeople, homepageProofOnly, leadPublication, limitItems, withBase } from "../lib/content";

const homepageProof = homepageProofOnly(publications);
const leadPaper = leadPublication(publications) ?? homepageProof[0];
const supportingPapers = homepageProof.filter((item) => item.title !== leadPaper?.title).slice(0, 2);
const homepageUpdates = limitItems(newsItems.filter((item) => item.homepageEligible ?? true), 2);
const currentRecord = [
  ...supportingPapers.map((item) => ({
    kind: "Publication",
    date: item.publishedAt ?? `${item.year}-01-01`,
    label: [item.journal, item.publishedAt ? formatMonthYear(item.publishedAt) : item.year].filter(Boolean).join(" / "),
    title: item.title,
    summary: item.significanceLine ?? item.summary,
    href: item.link,
    actionLabel: "Read paper"
  })),
  ...homepageUpdates.map((item) => ({
    kind: "Update",
    date: item.date,
    label: `${formatMonthYear(item.date)} / ${item.category}`,
    title: item.title,
    summary: item.summary,
    href: item.link,
    actionLabel: item.linkLabel ?? "Open source"
  }))
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const groupedPeople = groupPeople(peopleData.currentMembers);
const leadership = groupedPeople.find((group) => group.label === "Leadership");
const postdocs = groupedPeople.find((group) => group.label === "Postdoctoral Fellows & Instructors");
const students = groupedPeople.find((group) => group.label === "Graduate Students");
const currentMemberCount = peopleData.currentMembers.length;
---

<BaseLayout pageClass="page-home" socialImage={leadPaper?.image ?? siteData.heroFigures[0].image}>
  <section class="marquee">
    <div class="shell marquee__shell">
      <div class="marquee__grid">
        <div class="marquee__copy reveal">
          <p class="eyebrow">Abraham Lab</p>
          <h1>{siteData.heroTitle}</h1>
          <p class="marquee__deck">{siteData.heroDeck}</p>

          <div class="button-row">
            <a class="button button--primary" href={withBase("/publications/")}>View publications</a>
            <a class="button button--ghost" href={withBase("/jonathan-abraham/")}>Jonathan Abraham</a>
          </div>

          <dl class="marquee__facts">
            {siteData.heroFacts.map((item) => (
              <div class="marquee__fact">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <figure
          class="marquee__visual reveal"
          style={siteData.heroFigures[0]?.imagePosition ? `--media-position: ${siteData.heroFigures[0].imagePosition};` : undefined}
        >
          <img
            src={withBase(siteData.heroFigures[0].image)}
            alt={siteData.heroFigures[0].alt}
            loading="eager"
          />
          <figcaption class="marquee__caption">
            <p>{siteData.heroFigures[0].label}</p>
            <h2>{siteData.heroFigures[0].title}</h2>
            {siteData.heroFigures[0].note && <span>{siteData.heroFigures[0].note}</span>}
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="institution-strip">
    <div class="shell institution-strip__grid">
      <div class="institution-strip__copy reveal">
        <p class="eyebrow">{siteData.institutionLabel}</p>
        <h2 class="institution-strip__title">
          {siteData.contact.institutionDisplayLines?.map((line) => (
            line.includes("Blavatnik Institute") ? (
              <span>
                <span class="institution-strip__title-fragment">Blavatnik Institute</span>, Harvard Medical School
              </span>
            ) : (
              <span>{line}</span>
            )
          ))}
        </h2>
        <p>{siteData.institutionSummary}</p>
      </div>

      <div class="institution-strip__rail">
        {siteData.affiliations.map((affiliation) => (
          <a class="institution-strip__item reveal" href={affiliation.href} target="_blank" rel="noreferrer">
            <div class="institution-strip__logo">
              <img src={withBase(affiliation.logo)} alt={affiliation.alt} loading="lazy" />
            </div>
            <div>
              <p class="institution-strip__name">{affiliation.shortName ?? affiliation.name}</p>
              {affiliation.note && <p class="institution-strip__note">{affiliation.note}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {leadPaper && (
    <section class="section section--flagship proof-feature">
      <div class="shell section-heading section-heading--split">
        <div class="reveal">
          <p class="eyebrow">Lead publication</p>
          <h2>One recent paper from the lab.</h2>
        </div>
        <div class="reveal">
          <p>
            Recent work resolves how HSV-1 helicase-primase inhibitors interrupt replication
            and clarifies assembly of a herpesvirus replication fork complex.
          </p>
        </div>
      </div>

      <div class="shell editorial-feature editorial-feature--home">
        <div class="editorial-feature__copy reveal">
          <p class="eyebrow">{leadPaper.journal}</p>
          <h2>{leadPaper.title}</h2>
          <p class="editorial-feature__meta">
            {[leadPaper.publishedAt ? formatMonthYear(leadPaper.publishedAt) : undefined, leadPaper.pmid ? `PMID ${leadPaper.pmid}` : undefined].filter(Boolean).join(" / ")}
          </p>
          <p class="editorial-feature__summary">{leadPaper.summary}</p>
          <p class="citation-text">{leadPaper.citation}</p>
          <div class="button-row">
            <a class="button button--primary" href={leadPaper.link} target="_blank" rel="noreferrer">Read paper</a>
            {leadPaper.doi && <a class="button button--ghost" href={`https://doi.org/${leadPaper.doi}`} target="_blank" rel="noreferrer">DOI</a>}
          </div>
        </div>

        <div class="editorial-feature__visual reveal">
          <div class="frame editorial-feature__frame" style={leadPaper.imagePosition ? `--media-position: ${leadPaper.imagePosition};` : undefined}>
            <img src={withBase(leadPaper.image!)} alt={leadPaper.imageAlt!} loading="lazy" />
          </div>
        </div>

        <aside class="editorial-feature__rail reveal">
          <div class="metadata-stack">
            <p class="metadata-label">Published</p>
            <p>{leadPaper.publishedAt ? formatMonthYear(leadPaper.publishedAt) : leadPaper.year}</p>
          </div>
          <div class="metadata-stack">
            <p class="metadata-label">Venue</p>
            <p>{leadPaper.journal}</p>
          </div>
          {leadPaper.pmid && (
            <div class="metadata-stack">
              <p class="metadata-label">PubMed</p>
              <p>{leadPaper.pmid}</p>
            </div>
          )}
        </aside>
      </div>
    </section>
  )}

  <section class="section section--utility record-band">
    <div class="shell section-heading section-heading--split">
      <div class="reveal">
        <p class="eyebrow">Current record</p>
        <h2>Recent papers and public milestones.</h2>
      </div>
      <div class="reveal">
        <p>
          A short view of recent scientific output and major public updates from the lab.
        </p>
      </div>
    </div>

    <div class="shell">
      <section class="ledger-panel ledger-panel--dossier reveal">
        <div class="ledger-panel__header">
          <div>
            <p class="eyebrow">Recent record</p>
            <h2>Two recent papers and two recent milestones.</h2>
          </div>
          <div class="button-row">
            <a class="text-link" href={withBase("/publications/")}>Publications</a>
            <a class="text-link" href={withBase("/news/")}>News</a>
          </div>
        </div>

        <div class="updates-ledger">
          {currentRecord.map((item) => (
            <article class="updates-ledger__row reveal">
              <div class="updates-ledger__meta">
                <p>{item.kind}</p>
                <span>{item.label}</span>
              </div>
              <div class="updates-ledger__body">
                <h2><a href={item.href} target="_blank" rel="noreferrer">{item.title}</a></h2>
                {item.summary && <p>{item.summary}</p>}
              </div>
              <div class="updates-ledger__action">
                <a class="text-link" href={item.href} target="_blank" rel="noreferrer">{item.actionLabel}</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <section class="section section--utility lab-signal">
    <div class="shell lab-signal__grid">
      {leadership && leadership.entries[0] && (
        <div
          class="lab-signal__portrait frame reveal"
          style={leadership.entries[0].imagePosition ? `--media-position: ${leadership.entries[0].imagePosition};` : undefined}
        >
          <img src={withBase(leadership.entries[0].image)} alt={leadership.entries[0].imageAlt} loading="lazy" />
        </div>
      )}

      <div class="lab-signal__copy reveal">
        <p class="eyebrow">Leadership</p>
        <h2>Led by Jonathan Abraham at Harvard Medical School and HHMI.</h2>
        <p>
          The lab includes fellows, graduate students, and operations support working across structural
          virology and infection biology.
        </p>

        <div class="lab-signal__stats">
          <article>
            <span>{currentMemberCount}</span>
            <p>Current members</p>
          </article>
          <article>
            <span>{postdocs?.entries.length ?? 0}</span>
            <p>Postdoctoral fellows and instructors</p>
          </article>
          <article>
            <span>{students?.entries.length ?? 0}</span>
            <p>Graduate students</p>
          </article>
        </div>

        <div class="button-row">
          <a class="button button--primary" href={withBase("/people/")}>People</a>
          <a class="button button--ghost" href={withBase("/contact/")}>Contact</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
