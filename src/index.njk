---
layout: layouts/base.njk
title: Abraham Lab
description: The Abraham Lab studies viral entry, antibody neutralization, and polymerase function through structural biology and molecular virology.
bodyClass: page-home
---
{% set featuredPublications = publications | featuredOnly %}
{% set leadPublication = featuredPublications[0] %}
{% set recentNews = news | limit(3) %}

<section class="hero hero--mission">
  <div class="hero__media">
    <img
      src="{{ '/assets/images/research/hero-emergingvirus.jpg' | withBase }}"
      alt="Illustrated structural virology composition highlighting viral surface proteins and host receptor engagement."
    />
  </div>
  <div class="hero__scrim"></div>
  <div class="container hero__shell">
    <div class="hero__grid">
      <div class="hero__copy">
        <p class="eyebrow reveal">Structural virology | molecular virology | biophysics</p>
        <h1 class="reveal">{{ site.heroTitle }}</h1>
        <p class="hero__deck reveal">{{ site.heroDeck }}</p>
        <div class="hero__actions reveal">
          <a class="button button--primary" href="{{ '/research/' | withBase }}">Research</a>
          <a class="button button--secondary" href="{{ '/publications/' | withBase }}">Publications</a>
        </div>
      </div>
      <aside class="hero__dossier reveal">
        <p class="eyebrow">Laboratory profile</p>
        <div class="hero__dossier-list">
          {% for item in site.heroDossier %}
            <div class="hero__dossier-item">
              <span>{{ item.label }}</span>
              <p>{{ item.value }}</p>
            </div>
          {% endfor %}
        </div>
      </aside>
    </div>
</div>
</section>

<section class="affiliation-band">
  <div class="container affiliation-band__grid">
    <div class="affiliation-band__copy reveal">
      <p class="eyebrow">{{ site.institutionLabel }}</p>
      <h2>{{ site.institutionTitle }}</h2>
      <p>{{ site.institutionSummary }}</p>
    </div>
    <div class="affiliation-band__list">
      {% for affiliation in site.affiliations %}
        <a
          class="affiliation-band__item reveal"
          href="{{ affiliation.href }}"
          target="_blank"
          rel="noreferrer"
          aria-label="{{ affiliation.name }}"
        >
          <div class="affiliation-band__logo">
            <img src="{{ affiliation.logo | withBase }}" alt="{{ affiliation.alt }}" loading="lazy" />
          </div>
          <div class="affiliation-band__item-copy">
            <p class="affiliation-band__name">{{ affiliation.shortName or affiliation.name }}</p>
            {% if affiliation.note %}
              <p class="affiliation-band__note">{{ affiliation.note }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--flagship section--bordered">
  <div class="container program-showcase__intro">
    <div class="section-heading reveal">
      <p class="eyebrow">Scientific program</p>
      <h2>Mechanistic virology aimed at the points where intervention becomes possible.</h2>
      <p>
        The Abraham Lab uses molecular virology and structural biology to understand how viruses enter
        cells, evade neutralizing antibodies, and replicate, with a focus on emerging pathogens and
        human disease.
      </p>
    </div>
    <aside class="program-showcase__aside reveal">
      <p class="eyebrow">Why it matters</p>
      <p>
        By defining receptor usage, immune escape, and replication machinery at high resolution, the lab
        maps vulnerabilities relevant to countermeasure design, outbreak preparedness, and therapeutic
        strategy.
      </p>
    </aside>
  </div>

  <div class="container program-showcase">
    {% for item in research %}
      <article class="mission-chapter mission-chapter--home reveal">
        <p class="mission-chapter__index">{{ ("0" + loop.index) if loop.index < 10 else loop.index }}</p>
        <div class="mission-chapter__visual">
          <img src="{{ item.image | withBase }}" alt="{{ item.imageAlt }}" loading="lazy" />
        </div>
        <div class="mission-chapter__body">
          <h3>{{ item.title }}</h3>
          <p class="mission-chapter__lead">{{ item.importance }}</p>
          <p>{{ item.summary }}</p>
        </div>
        <aside class="mission-chapter__meta">
          <div class="mission-chapter__meta-block">
            <span>Representative systems</span>
            <p>{{ item.systems | join(", ") }}</p>
          </div>
          <div class="mission-chapter__meta-block">
            <span>Representative paper</span>
            <p><a href="{{ item.relatedLink }}" target="_blank" rel="noreferrer">{{ item.relatedPublication }}</a></p>
          </div>
          <div class="mission-chapter__meta-block">
            <span>Research</span>
            <p><a class="text-link" href="{{ '/research/' | withBase }}">View the research program</a></p>
          </div>
        </aside>
      </article>
    {% endfor %}
  </div>
</section>

<section class="section section--soft section--flagship">
  <div class="container section-heading reveal">
    <p class="eyebrow">Selected publication</p>
    <h2>One representative paper from the current research program.</h2>
  </div>

  {% if leadPublication %}
    <div class="container editorial-feature publication-focus reveal">
      <div class="editorial-feature__visual">
        <img src="{{ leadPublication.image | withBase }}" alt="{{ leadPublication.imageAlt }}" loading="lazy" />
      </div>
      <div class="editorial-feature__body">
        <p class="eyebrow">Lead paper</p>
        <h3>{{ leadPublication.title }}</h3>
        <p class="editorial-feature__summary">{{ leadPublication.summary }}</p>
        <p class="publication-meta">
          {{ leadPublication.year }}{% if leadPublication.doi %} | {{ leadPublication.doi }}{% endif %}
        </p>
        <p class="citation-text">{{ leadPublication.citation }}</p>
        <a class="button button--primary" href="{{ leadPublication.link }}" target="_blank" rel="noreferrer">Read publication</a>
      </div>
      <aside class="publication-focus__rail">
        <p class="eyebrow">Publications</p>
        <p>
          Additional publications span viral entry, antibody biology, and replication mechanisms.
        </p>
        <a class="text-link" href="{{ '/publications/' | withBase }}">View full publication archive</a>
      </aside>
    </div>
  {% endif %}
</section>

<section class="section section--utility section--bordered">
  <div class="container updates-overview">
    <div class="updates-overview__copy reveal">
      <p class="eyebrow">Updates</p>
      <h2>Recent news and coverage.</h2>
      <p>
        Selected updates on publications, awards, invited talks, grants, and institutional coverage from
        the Abraham Lab.
      </p>
      <div class="public-updates">
        <a class="public-updates__item" href="{{ site.social.x }}" target="_blank" rel="noreferrer">
          <span class="public-updates__label">X</span>
          <span class="public-updates__text">Follow lab updates on X</span>
        </a>
        <a class="public-updates__item" href="{{ site.social.bluesky }}" target="_blank" rel="noreferrer">
          <span class="public-updates__label">Bluesky</span>
          <span class="public-updates__text">Follow lab updates on Bluesky</span>
        </a>
      </div>
    </div>

    <div class="updates-overview__list">
      {% for item in recentNews %}
        <article class="update-row reveal">
          <div class="update-row__meta">
            <p class="eyebrow">{{ item.category }}</p>
            <p>{{ item.dateLabel }}</p>
          </div>
          <div class="update-row__body">
            <p class="update-row__source">{{ item.sourceType }}</p>
            <h3>{{ item.title }}</h3>
            <p>{{ item.summary }}</p>
          </div>
          <div class="update-row__action">
            <a class="text-link" href="{{ item.link }}" target="_blank" rel="noreferrer">{{ item.linkLabel or "Open source" }}</a>
          </div>
        </article>
      {% endfor %}
      <div class="updates-overview__footer reveal">
        <a class="button button--secondary" href="{{ '/news/' | withBase }}">View all updates</a>
      </div>
    </div>
  </div>
</section>

<section class="section section--soft section--utility">
  <div class="container location-feature">
    <div class="location-feature__copy reveal">
      <p class="eyebrow">Location</p>
      <h2>{{ site.contact.homeLocationLabel }}</h2>
      <p>For collaborations, speaking requests, and administrative inquiries.</p>
      <div class="location-feature__address">
        {% for line in site.contact.addressLines %}
          <p>{{ line }}</p>
        {% endfor %}
      </div>
      <div class="location-feature__actions">
        <a class="button button--primary" href="mailto:{{ site.contact.email }}">Email Jonathan Abraham</a>
        <a class="button button--secondary" href="{{ '/contact/' | withBase }}">Contact details</a>
      </div>
    </div>

    {% set mapEyebrow = "Campus location" %}
    {% set mapDescription = "Longwood Medical Area, Boston" %}
    {% set mapCardClass = "map-card--home" %}
    {% include "partials/map-card.njk" %}
  </div>
</section>
