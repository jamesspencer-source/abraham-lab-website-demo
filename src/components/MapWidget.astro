---
import { siteData } from "../data/site";
import { withBase } from "../lib/content";

interface Props {
  eyebrow?: string;
  description?: string;
  mode?: "home" | "contact";
}

const { eyebrow = "Location", description, mode = "home" } = Astro.props;
---

<aside class:list={["map-widget", `map-widget--${mode}`, "reveal"]}>
  <a class="map-widget__media frame" href={siteData.contact.mapUrl} target="_blank" rel="noreferrer">
    <img src={withBase(siteData.contact.mapPreviewImage)} alt={siteData.contact.mapPreviewAlt} loading="lazy" />
  </a>

  <div class="map-widget__body">
    <p class="eyebrow">{eyebrow}</p>
    <h3>{siteData.contact.mapBuilding}</h3>
    <p class="map-widget__campus">{siteData.contact.mapDisplayName}</p>
    {description && <p class="map-widget__description">{description}</p>}
    <div class="map-widget__address">
      {siteData.contact.addressLines.map((line) => <p>{line}</p>)}
    </div>
    <div class="map-widget__actions">
      <a class="text-link" href={siteData.contact.mapUrl} target="_blank" rel="noreferrer">Open in Google Maps</a>
    </div>
  </div>
</aside>
