---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import MissionChapter from "../../components/MissionChapter.astro";
import { researchPrograms } from "../../data/research";
---

<BaseLayout title="Research" description="Research themes in viral entry, antibody neutralization, and viral polymerase biology at the Abraham Lab.">
  <PageHero
    eyebrow="Research"
    title="Three connected scientific programs in viral infection biology."
    description="The lab's work is organized around entry, neutralization, and replication. In each area, structural and mechanistic detail is used to identify leverage points for antiviral intervention."
    meta={[
      {
        label: "Core systems",
        value: "alphaviruses, arenaviruses, herpesviruses, and other medically significant viral families"
      },
      {
        label: "Core methods",
        value: "cryo-EM, crystallography, protein biochemistry, genetics, and infection-focused functional assays"
      },
      {
        label: "Program aim",
        value: "mechanistic resolution of therapeutic vulnerability in human viral disease"
      }
    ]}
  />

  <section class="section section--flagship">
    <div class="shell mission-list">
      {researchPrograms.map((item, index) => (
        <MissionChapter
          index={index + 1}
          title={item.title}
          lead={item.importance}
          body={[item.summary, ...item.paragraphs]}
          image={item.image}
          imageAlt={item.imageAlt}
          imagePosition={item.imagePosition}
          headingTag="h2"
          meta={[
            { label: "Program focus", text: item.lead },
            { label: "Representative systems", items: item.systems },
            { label: "Representative methods", items: item.methods },
            {
              label: "Representative paper",
              href: item.relatedLink,
              hrefLabel: item.relatedPublication
            }
          ]}
        />
      ))}
    </div>
  </section>

  <section class="section section--soft section--utility">
    <div class="shell support-band reveal">
      <div>
        <p class="eyebrow">Approach</p>
        <h2>Integrated structure, biophysics, and infection biology.</h2>
      </div>
      <div>
        <p>
          The Abraham Lab connects molecular structure with biological consequence through an experimental
          program that spans discovery genetics, protein science, structural analysis, and infection-focused assays.
        </p>
      </div>
      <div class="support-band__list">
        <p>CRISPR-based discovery</p>
        <p>Protein biochemistry</p>
        <p>Cryo-EM and crystallography</p>
        <p>Functional virology</p>
      </div>
    </div>
  </section>
</BaseLayout>
