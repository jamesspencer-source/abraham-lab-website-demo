---
interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  meta?: MetaItem[];
}

const { eyebrow, title, description, meta = [] } = Astro.props;
---

<section class="page-hero">
  <div class="shell page-hero__inner">
    <div class="page-hero__copy reveal">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>

    {meta.length > 0 && (
      <div class="page-hero__meta reveal">
        {meta.map((item) => (
          <div class="meta-block">
            <span>{item.label}</span>
            <p>{item.value}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
