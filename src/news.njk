---
layout: layouts/base.njk
title: News
description: Science-facing updates from the Abraham Lab.
permalink: /news/index.html
---
{% set leadNews = news[0] %}

<section class="page-hero page-hero--light">
  <div class="container page-hero__content reveal">
    <p class="eyebrow">News</p>
    <h1>Science updates.</h1>
    <p>Public-facing updates on papers, grants, awards, and major milestones in the Abraham Lab research program.</p>
  </div>
</section>

{% if leadNews %}
  <section class="section section--bordered">
    <div class="container editorial-feature editorial-feature--news reveal">
      <div class="editorial-feature__visual">
        <img src="{{ leadNews.image }}" alt="{{ leadNews.imageAlt }}" loading="lazy" />
      </div>
      <div class="editorial-feature__body">
        <p class="eyebrow">{{ leadNews.category }}</p>
        <h2>{{ leadNews.title }}</h2>
        <p class="editorial-feature__summary">{{ leadNews.summary }}</p>
        <p class="publication-meta">{{ leadNews.dateLabel }}</p>
        <a class="button button--primary" href="{{ leadNews.link }}" target="_blank" rel="noreferrer">Open source</a>
      </div>
      <aside class="editorial-feature__rail">
        <p class="eyebrow">Editorial standard</p>
        <p>
          This feed is limited to research-facing items, including publications, grants, invited talks,
          awards, and major scientific milestones.
        </p>
      </aside>
    </div>
  </section>
{% endif %}

<section class="section">
  <div class="container update-list">
    {% for item in news %}
      {% if not loop.first %}
        <article class="update-row reveal">
          <div class="update-row__meta">
            <p class="eyebrow">{{ item.category }}</p>
            <p>{{ item.dateLabel }}</p>
          </div>
          <div class="update-row__body">
            <h3>{{ item.title }}</h3>
            <p>{{ item.summary }}</p>
          </div>
          <div class="update-row__action">
            <a class="text-link" href="{{ item.link }}" target="_blank" rel="noreferrer">Open source</a>
          </div>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
